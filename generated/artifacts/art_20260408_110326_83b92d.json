    "steps": [
      {
        "id": "start_1",
        "type": "start",
        "config": {}
      },
      {
        "id": "detect_language",
        "type": "llm",
        "config": {
          "prompt": "请分析以下文本并识别其语言。只返回语言名称，例如：中文、英语、日语、法语等。\n文本：{{source_text}}",
          "model": "deepseek-chat",
          "max_tokens": 50
        }
      },
      {
        "id": "translate_text",
        "type": "llm",
        "config": {
          "prompt": "请将以下{{detected_source_language}}文本翻译成{{target_language}}。保持原文的风格和语气，确保翻译准确自然。\n原文：{{source_text}}",
          "model": "deepseek-chat",
          "max_tokens": 2000
        }
      },
      {
        "id": "quality_check",
        "type": "llm",
        "config": {
          "prompt": "请评估以下翻译的质量，从1-10分打分（10分为最佳），并简要说明理由。\n源语言：{{detected_source_language}}\n目标语言：{{target_language}}\n原文：{{source_text}}\n译文：{{translated_text}}\n\n请以JSON格式返回：{\"score\": 分数, \"reason\": \"理由\"}",
          "model": "deepseek-chat",
          "max_tokens": 300
        }
      },
      {
        "id": "format_output",
        "type": "template",
        "config": {
          "template": "翻译完成！\n\n📝 源文本：{{source_text}}\n🌐 检测到的源语言：{{detected_source_language}}\n🎯 目标语言：{{target_language}}\n✨ 翻译结果：{{translated_text}}\n⭐ 质量评分：{{quality_score}}/10\n📋 评分理由：{{quality_reason}}",
          "variables": [
            "source_text",
            "detected_source_language",
            "target_language",
            "translated_text",
            "quality_score",
            "quality_reason"
          ]
        }
      },
