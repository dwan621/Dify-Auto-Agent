  "selected_spec": {
    "workflow_name": "智能意图处理工作流",
    "description": "通过意图分析自动选择并执行合适的处理路径（检索、工具调用或代码执行），最终获得格式统一的处理结果",
    "scene": "generic",
    "inputs": [
      {
        "name": "user_input",
        "label": "用户输入",
        "type": "paragraph",
        "required": true
      },
      {
        "name": "additional_context",
        "label": "附加上下文",
        "type": "text",
        "required": false
      },
      {
        "name": "reference_files",
        "label": "参考文件",
        "type": "file",
        "required": false
      }
    ],
    "output_contract": {
      "format": "structured_json",
      "fields": [
        "intent_type",
        "processed_results",
        "execution_path",
        "formatted_output"
      ]
    },
    "steps": [
      {
        "id": "start",
        "type": "start",
        "config": {}
      },
      {
        "id": "intent_analysis",
        "type": "llm",
        "config": {
          "model": "deepseek-chat",
          "prompt": "分析用户输入的意图类型。可能的意图类型包括：1) information_retrieval - 需要检索信息 2) data_processing - 需要代码处理数据 3) api_call - 需要调用外部工具API 4) other - 其他类型。输出JSON格式：{\"intent_type\": \"意图类型\", \"reasoning\": \"分析理由\"}",
          "variables": {
            "user_input": "{{inputs.user_input}}",
            "additional_context": "{{inputs.additional_context}}"
          }
        }
      },
      {
        "id": "intent_branch",
        "type": "ifelse",
        "config": {
          "condition": "{{steps.intent_analysis.output.intent_type}}",
          "cases": [
            {
              "id": "retrieval_branch",
              "value": "information_retrieval",
              "label": "检索分支"
            },
            {
              "id": "code_branch",
              "value": "data_processing",
              "label": "代码处理分支"
            },
            {
              "id": "tool_branch",
              "value": "api_call",
              "label": "工具调用分支"
            },
            {
              "id": "other_branch",
              "value": "other",
              "label": "其他分支"
            }
          ]
        }
      },
      {
        "id": "knowledge_retrieval",
        "type": "knowledge_retrieval",
        "config": {
          "query": "{{inputs.user_input}}",
          "top_k": 5,
          "threshold": 0.7
        }
      },
      {
        "id": "data_processing_code",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import json\nimport re\n\ndef process_data(user_input, context=None):\n    \"\"\"处理用户输入的数据\"\"\"\n    # 示例：提取数字和文本\n    numbers = re.findall(r'\\d+', user_input)\n    words = re.findall(r'[A-Za-z]+', user_input)\n    \n    result = {\n        \"extracted_numbers\": [int(n) for n in numbers],\n        \"extracted_words\": words,\n        \"total_numbers\": len(numbers),\n        \"total_words\": len(words),\n        \"context\": context\n    }\n    return json.dumps(result, ensure_ascii=False)",
          "example_key": "clean_text",
          "variables": {
            "user_input": "{{inputs.user_input}}",
            "context": "{{inputs.additional_context}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "api_tool_call",
        "type": "tool",
        "config": {
          "method": "get",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json",
            "User-Agent": "IntentWorkflow/1.0"
          },
          "body": null,
          "variables": {
            "query_param": "{{inputs.user_input}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "other_intent_handler",
        "type": "llm",
        "config": {
          "model": "deepseek-chat",
          "prompt": "处理其他类型的意图。用户输入：{{inputs.user_input}}。请分析并生成适当的响应。",
          "variables": {
            "user_input": "{{inputs.user_input}}"
          }
        }
      },
      {
        "id": "code_error_handler",
        "type": "llm",
        "config": {
          "model": "deepseek-chat",
          "prompt": "代码执行失败处理。原始输入：{{inputs.user_input}}。错误信息：{{steps.data_processing_code.error}}。请生成错误处理响应。",
          "variables": {
            "user_input": "{{inputs.user_input}}"
          }
        }
      },
      {
        "id": "tool_error_handler",
        "type": "llm",
        "config": {
          "model": "deepseek-chat",
          "prompt": "工具调用失败处理。原始输入：{{inputs.user_input}}。错误信息：{{steps.api_tool_call.error}}。请生成错误处理响应。",
          "variables": {
            "user_input": "{{inputs.user_input}}"
          }
        }
      },
      {
        "id": "results_aggregator",
        "type": "variable_aggregator",
        "config": {
          "variables": {
            "intent_type": "{{steps.intent_analysis.output.intent_type}}",
            "retrieval_results": "{{steps.knowledge_retrieval.output}}",
            "code_results": "{{steps.data_processing_code.output}}",
            "code_error_results": "{{steps.code_error_handler.output}}",
            "tool_results": "{{steps.api_tool_call.output}}",
            "tool_error_results": "{{steps.tool_error_handler.output}}",
            "other_results": "{{steps.other_intent_handler.output}}",
            "execution_path": "{{steps.intent_branch.output.selected_branch}}"
          }
        }
      },
      {
        "id": "format_output",
        "type": "template",
        "config": {
          "template": "{\n  \"intent_type\": \"{{aggregated.intent_type}}\",\n  \"processed_results\": {\n    \"retrieval\": {{aggregated.retrieval_results | tojson}},\n    \"code_processing\": {{aggregated.code_results | tojson}},\n    \"code_error\": {{aggregated.code_error_results | tojson}},\n    \"tool_call\": {{aggregated.tool_results | tojson}},\n    \"tool_error\": {{aggregated.tool_error_results | tojson}},\n    \"other\": {{aggregated.other_results | tojson}}\n  },\n  \"execution_path\": \"{{aggregated.execution_path}}\",\n  \"formatted_output\": \"意图类型：{{aggregated.intent_type}}，执行路径：{{aggregated.execution_path}}，已成功处理用户请求。\"\n}",
          "variables": {
            "aggregated": "{{steps.results_aggregator.output}}"
          }
        }
      },
      {
        "id": "answer",
        "type": "answer",
        "config": {
          "answer": "{{steps.format_output.output}}"
        }
      }
    ],
    "edges": [
