        "metadata": "处理元数据"
      },
      "consistency": "所有分支输出必须遵循统一格式"
    },
    "steps": [
      {
        "id": "start_1",
        "type": "start",
        "config": {
          "name": "开始节点",
          "description": "接收用户输入"
        }
      },
      {
        "id": "intent_analysis_1",
        "type": "llm",
        "config": {
          "name": "意图分析",
          "description": "分析用户输入的意图类型",
          "model": "deepseek-chat",
          "prompt": "分析以下用户输入的意图类型，从以下选项中选择：\n1. information_retrieval - 需要检索信息\n2. tool_execution - 需要调用外部工具\n3. data_processing - 需要代码处理数据\n4. general_query - 一般性查询\n\n用户输入：{{user_input}}\n附加上下文：{{additional_context}}\n\n请以JSON格式返回：{\"intent\": \"意图类型\", \"confidence\": 置信度分数, \"reasoning\": \"分析理由\"}",
          "variables": [
            "user_input",
            "additional_context"
          ]
        }
      },
      {
        "id": "planning_1",
        "type": "llm",
        "config": {
          "name": "执行规划",
          "description": "根据意图制定执行计划",
          "model": "deepseek-chat",
          "prompt": "根据意图分析结果，制定具体的执行计划。\n意图分析结果：{{intent_analysis_1.output}}\n\n请规划具体的执行步骤，包括需要检索的关键词、需要调用的工具、需要处理的数据等。\n以JSON格式返回：{\"plan\": \"执行计划描述\", \"keywords\": [\"关键词1\", \"关键词2\"], \"tool_needed\": \"是/否\", \"code_needed\": \"是/否\"}",
          "variables": [
            "intent_analysis_1.output"
          ]
        }
      },
      {
        "id": "branch_decision_1",
        "type": "ifelse",
        "config": {
          "name": "分支决策",
          "description": "根据意图类型选择执行路径",
          "condition": "{{intent_analysis_1.output.intent}}",
          "cases": [
            {
              "id": "retrieval_branch",
              "condition": "information_retrieval",
              "name": "检索分支"
            },
            {
              "id": "tool_branch",
              "condition": "tool_execution",
              "name": "工具调用分支"
            },
            {
              "id": "code_branch",
              "condition": "data_processing",
              "name": "代码处理分支"
            },
            {
              "id": "general_branch",
              "condition": "general_query",
              "name": "通用查询分支"
            }
          ]
        }
      },
      {
        "id": "knowledge_retrieval_1",
        "type": "knowledge_retrieval",
        "config": {
          "name": "知识检索",
          "description": "从知识库检索相关信息",
          "knowledge_base_id": "private_kb_001",
          "query": "{{planning_1.output.keywords}}",
          "top_k": 5,
          "threshold": 0.7
        }
      },
      {
        "id": "tool_call_1",
        "type": "tool",
        "config": {
          "name": "外部工具调用",
          "description": "调用外部API执行操作",
          "method": "post",
          "url": "https://httpbin.org/post",
          "headers": {
            "Content-Type": "application/json",
            "User-Agent": "智能意图处理工作流"
          },
          "body": {
            "user_input": "{{user_input}}",
            "intent": "{{intent_analysis_1.output.intent}}",
            "plan": "{{planning_1.output.plan}}"
          },
          "variables": [
            "user_input",
            "intent_analysis_1.output",
            "planning_1.output"
          ],
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "code_processing_1",
        "type": "code",
        "config": {
          "name": "代码处理",
          "description": "执行数据清洗和格式化",
          "language": "python",
          "script": "def process_data(user_input, additional_context=None):\n    # 数据清洗和预处理\n    import json\n    import re\n    \n    # 清理文本\n    cleaned_text = re.sub(r'[\\x00-\\x1f\\x7f-\\x9f]', '', user_input)\n    cleaned_text = cleaned_text.strip()\n    \n    # 尝试解析JSON\n    try:\n        if additional_context:\n            data = json.loads(additional_context)\n            return {\"status\": \"success\", \"cleaned_input\": cleaned_text, \"parsed_context\": data}\n        else:\n            return {\"status\": \"success\", \"cleaned_input\": cleaned_text, \"parsed_context\": None}\n    except json.JSONDecodeError:\n        return {\"status\": \"error\", \"cleaned_input\": cleaned_text, \"error\": \"无法解析JSON上下文\"}",
          "example_key": "clean_text",
          "variables": [
            "user_input",
            "additional_context"
          ]
        }
      },
      {
        "id": "general_processing_1",
        "type": "llm",
        "config": {
          "name": "通用查询处理",
          "description": "处理一般性查询",
          "model": "deepseek-chat",
          "prompt": "处理以下一般性查询：\n用户输入：{{user_input}}\n附加上下文：{{additional_context}}\n\n请提供详细、准确的回答。",
          "variables": [
            "user_input",
            "additional_context"
          ]
        }
      },
      {
        "id": "tool_fallback_1",
        "type": "llm",
        "config": {
          "name": "工具调用失败处理",
          "description": "工具调用失败时的备选处理",
          "model": "deepseek-chat",
          "prompt": "工具调用失败，请基于以下信息提供替代方案：\n用户输入：{{user_input}}\n意图：{{intent_analysis_1.output.intent}}\n失败原因：{{tool_call_1.error}}\n\n请提供替代的处理结果。",
          "variables": [
            "user_input",
            "intent_analysis_1.output",
            "tool_call_1.error"
          ]
        }
      },
      {
        "id": "results_aggregator_1",
        "type": "variable_aggregator",
        "config": {
          "name": "结果聚合",
          "description": "聚合所有分支的处理结果",
          "variables": [
            {
              "name": "intent_analysis_result",
              "source": "intent_analysis_1.output"
            },
            {
              "name": "planning_result",
              "source": "planning_1.output"
            },
            {
              "name": "branch_results",
              "source": "branch_decision_1.selected_branch"
            },
            {
              "name": "execution_results",
              "source": "knowledge_retrieval_1.output || tool_call_1.output || code_processing_1.output || general_processing_1.output || tool_fallback_1.output"
            }
          ]
        }
      },
      {
        "id": "formatting_1",
        "type": "template",
        "config": {
          "name": "结果格式化",
          "description": "统一格式化所有分支的输出结果",
          "template": "# 智能意图处理结果\n\n## 意图识别\n- **意图类型**: {{intent_analysis_result.intent}}\n- **置信度**: {{intent_analysis_result.confidence}}\n- **分析理由**: {{intent_analysis_result.reasoning}}\n\n## 执行路径\n- **执行计划**: {{planning_result.plan}}\n- **实际路径**: {{branch_results}}\n\n## 处理结果\n{{execution_results}}\n\n## 元数据\n- **处理时间**: {{timestamp}}\n- **工作流版本**: 1.0\n- **模型**: deepseek-chat",
          "variables": [
            "intent_analysis_result",
            "planning_result",
            "branch_results",
            "execution_results"
          ]
        }
      },
      {
        "id": "answer_1",
        "type": "answer",
        "config": {
          "name": "最终输出",
          "description": "输出格式统一的处理结果"
