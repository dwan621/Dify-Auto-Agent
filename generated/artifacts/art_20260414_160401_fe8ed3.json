        "formatted_output"
      ]
    },
    "steps": [
      {
        "id": "start_1",
        "type": "start",
        "config": {
          "input_mapping": {
            "user_input": "{{inputs.user_input}}",
            "additional_context": "{{inputs.additional_context}}",
            "reference_files": "{{inputs.reference_files}}"
          }
        }
      },
      {
        "id": "intent_analysis",
        "type": "llm",
        "config": {
          "model": "deepseek-chat",
          "prompt": "分析用户输入的意图类型。可能的意图类型包括：信息检索（需要从知识库查找信息）、工具调用（需要调用外部API）、数据处理（需要执行代码处理）、综合任务（需要多步骤处理）。请输出JSON格式：{\"intent_type\": \"类型名称\", \"confidence\": 置信度分数, \"reasoning\": \"分析理由\"}",
          "variables": {
            "user_input": "{{steps.start_1.output.user_input}}",
            "additional_context": "{{steps.start_1.output.additional_context}}"
          }
        }
      },
      {
        "id": "intent_router",
        "type": "ifelse",
        "config": {
          "condition": "{{steps.intent_analysis.output.intent_type}}",
          "cases": [
            {
              "id": "retrieval_branch",
              "condition": "信息检索",
              "description": "需要从知识库检索信息"
            },
            {
              "id": "tool_branch",
              "condition": "工具调用",
              "description": "需要调用外部API工具"
            },
            {
              "id": "code_branch",
              "condition": "数据处理",
              "description": "需要执行代码处理数据"
            },
            {
              "id": "default_branch",
              "condition": "default",
              "description": "其他意图类型，使用LLM直接处理"
            }
          ]
        }
      },
      {
        "id": "knowledge_retrieval",
        "type": "knowledge_retrieval",
        "config": {
          "query": "{{steps.intent_analysis.output.reasoning}} {{steps.start_1.output.user_input}}",
          "top_k": 5,
          "score_threshold": 0.7,
          "variables": {
            "user_input": "{{steps.start_1.output.user_input}}"
          }
        }
      },
      {
        "id": "github_api_tool",
        "type": "tool",
        "config": {
          "method": "get",
          "url": "https://api.github.com/search/repositories",
          "headers": {
            "Accept": "application/vnd.github.v3+json",
            "User-Agent": "Workflow-Agent"
          },
          "body": null,
          "variables": {
            "query": "{{steps.start_1.output.user_input}}",
            "sort": "stars",
            "order": "desc",
            "per_page": 3
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_processing_code",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import json\nimport re\n\ndef clean_text(text):\n    \"\"\"清理文本数据\"\"\"\n    if not text:\n        return \"\"\n    # 移除多余空白字符\n    text = re.sub(r'\\s+', ' ', text)\n    # 移除特殊字符但保留基本标点\n    text = re.sub(r'[^\\w\\s.,!?\\-\\:\\;\\(\\)\\[\\]\\{\\}]', '', text)\n    return text.strip()\n\n# 主处理逻辑\ninput_data = {{steps.start_1.output.user_input}}\nif isinstance(input_data, dict):\n    input_data = json.dumps(input_data)\n\ncleaned = clean_text(input_data)\nresult = {\n    \"original_length\": len(input_data),\n    \"cleaned_length\": len(cleaned),\n    \"cleaned_text\": cleaned,\n    \"processing_time\": \"completed\"\n}\noutput = json.dumps(result, ensure_ascii=False)",
          "example_key": "clean_text",
          "variables": {
            "user_input": "{{steps.start_1.output.user_input}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "llm_direct_processing",
        "type": "llm",
        "config": {
          "model": "deepseek-chat",
          "prompt": "直接处理用户请求：{{steps.start_1.output.user_input}}\n\n附加上下文：{{steps.start_1.output.additional_context}}\n\n请提供详细、准确的回答。",
          "variables": {
            "user_input": "{{steps.start_1.output.user_input}}",
            "additional_context": "{{steps.start_1.output.additional_context}}"
          }
        }
      },
      {
        "id": "tool_fallback",
        "type": "llm",
        "config": {
          "model": "deepseek-chat",
          "prompt": "工具调用失败，请直接处理用户请求：{{steps.start_1.output.user_input}}\n\n失败信息：{{steps.github_api_tool.error}}\n\n请提供替代解决方案。",
          "variables": {
            "user_input": "{{steps.start_1.output.user_input}}",
            "error": "{{steps.github_api_tool.error}}"
          }
        }
      },
      {
        "id": "code_fallback",
        "type": "llm",
        "config": {
          "model": "deepseek-chat",
          "prompt": "代码执行失败，请直接处理用户请求：{{steps.start_1.output.user_input}}\n\n失败信息：{{steps.data_processing_code.error}}\n\n请提供替代解决方案。",
          "variables": {
            "user_input": "{{steps.start_1.output.user_input}}",
            "error": "{{steps.data_processing_code.error}}"
          }
        }
      },
      {
        "id": "results_aggregator",
        "type": "variable_aggregator",
        "config": {
          "aggregation_strategy": "merge",
          "variables": {
            "intent_analysis": "{{steps.intent_analysis.output}}",
            "retrieval_results": "{{steps.knowledge_retrieval.output}}",
            "tool_results": "{{steps.github_api_tool.output}}",
            "tool_fallback_results": "{{steps.tool_fallback.output}}",
            "code_results": "{{steps.data_processing_code.output}}",
            "code_fallback_results": "{{steps.code_fallback.output}}",
            "llm_results": "{{steps.llm_direct_processing.output}}",
            "execution_path": "{{steps.intent_router.output.selected_branch}}"
          }
        }
      },
      {
        "id": "formatting_template",
        "type": "template",
        "config": {
          "template": "{\n  \"intent_type\": \"{{steps.results_aggregator.output.intent_analysis.intent_type}}\",\n  \"processed_results\": {\n    \"retrieval\": {{steps.results_aggregator.output.retrieval_results | tojson}},\n    \"tool\": {{steps.results_aggregator.output.tool_results | tojson}},\n    \"tool_fallback\": {{steps.results_aggregator.output.tool_fallback_results | tojson}},\n    \"code\": {{steps.results_aggregator.output.code_results | tojson}},\n    \"code_fallback\": {{steps.results_aggregator.output.code_fallback_results | tojson}},\n    \"llm\": {{steps.results_aggregator.output.llm_results | tojson}}\n  },\n  \"execution_path\": \"{{steps.results_aggregator.output.execution_path}}\",\n  \"formatted_output\": \"意图类型'{{steps.results_aggregator.output.intent_analysis.intent_type}}'的处理已完成。置信度：{{steps.results_aggregator.output.intent_analysis.confidence}}。\"\n}",
          "variables": {
            "intent_analysis": "{{steps.results_aggregator.output.intent_analysis}}",
            "retrieval_results": "{{steps.results_aggregator.output.retrieval_results}}",
            "tool_results": "{{steps.results_aggregator.output.tool_results}}",
            "tool_fallback_results": "{{steps.results_aggregator.output.tool_fallback_results}}",
            "code_results": "{{steps.results_aggregator.output.code_results}}",
            "code_fallback_results": "{{steps.results_aggregator.output.code_fallback_results}}",
            "llm_results": "{{steps.results_aggregator.output.llm_results}}",
            "execution_path": "{{steps.results_aggregator.output.execution_path}}"
          }
        }
      },
      {
        "id": "final_answer",
        "type": "answer",
