            "sales_timeout_warning": "{{steps.timeout_check_1.output}}",
            "converted_opportunities": "{{steps.first_contact_judge_1.output.opportunity}}",
            "lost_leads_archive": "{{steps.first_contact_judge_1.output.lost}}",
            "nurture_leads_list": "{{steps.first_contact_judge_1.output.nurture}}",
            "summary_report": "{{steps.report_generation_1.output}}"
          }
        }
      },
