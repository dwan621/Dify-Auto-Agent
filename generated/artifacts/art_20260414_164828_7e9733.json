      {
        "id": "input_check_1",
        "type": "code",
        "config": {
          "name": "输入数据校验",
          "language": "python",
          "script": "import pandas as pd\nimport json\ndef main(raw_leads_data, scoring_criteria, budget_threshold, source_priority_list, vip_assignment_rules, public_pool_matching_rules, timeout_duration, first_contact_outcome_definitions):\n    # 读取文件\n    try:\n        df = pd.read_csv(raw_leads_data)\n    except Exception as e:\n        return {'error': f'文件读取失败: {e}'}\n    # 检查必要列\n    required_cols = ['lead_id', 'name', 'contact', 'source', 'budget', 'create_time']\n    missing = [col for col in required_cols if col not in df.columns]\n    if missing:\n        return {'error': f'缺少必要列: {missing}'}\n    # 返回校验结果\n    return {\n        'status': 'success',\n        'data': df.to_dict('records'),\n        'scoring_criteria': scoring_criteria,\n        'budget_threshold': budget_threshold,\n        'source_priority_list': source_priority_list,\n        'vip_assignment_rules': vip_assignment_rules,\n        'public_pool_matching_rules': public_pool_matching_rules,\n        'timeout_duration': timeout_duration,\n        'first_contact_outcome_definitions': first_contact_outcome_definitions\n    }",
          "example_key": "parse_json",
          "variables": {
            "raw_leads_data": "{{inputs.raw_leads_data}}",
            "scoring_criteria": "{{inputs.scoring_criteria}}",
            "budget_threshold": "{{inputs.budget_threshold}}",
            "source_priority_list": "{{inputs.source_priority_list}}",
            "vip_assignment_rules": "{{inputs.vip_assignment_rules}}",
            "public_pool_matching_rules": "{{inputs.public_pool_matching_rules}}",
            "timeout_duration": "{{inputs.timeout_duration}}",
            "first_contact_outcome_definitions": "{{inputs.first_contact_outcome_definitions}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_clean_1",
        "type": "code",
        "config": {
          "name": "数据清洗",
          "language": "python",
          "script": "import pandas as pd\ndef main(data):\n    df = pd.DataFrame(data)\n    # 去重\n    df = df.drop_duplicates(subset=['lead_id'])\n    # 处理缺失值\n    df['name'] = df['name'].fillna('未知')\n    df['contact'] = df['contact'].fillna('')\n    df['budget'] = pd.to_numeric(df['budget'], errors='coerce').fillna(0)\n    # 标准化来源\n    df['source'] = df['source'].str.strip().str.lower()\n    # 返回清洗后数据\n    return df.to_dict('records')",
          "example_key": "clean_text",
          "variables": {
            "data": "{{steps.input_check_1.output.data}}"
          }
        }
      },
      {
        "id": "knowledge_retrieval_1",
        "type": "knowledge_retrieval",
        "config": {
          "name": "检索评分规则",
          "query": "{{steps.input_check_1.output.scoring_criteria}}",
          "knowledge_base_id": "scoring_rules_kb"
        }
      },
      {
        "id": "llm_scoring_1",
        "type": "llm",
        "config": {
          "name": "智能线索评分",
          "prompt": "你是一个线索评分专家。请根据以下评分规则和线索数据，为每条线索计算一个综合得分（0-100分）。\n\n评分规则：\n{{steps.knowledge_retrieval_1.output}}\n\n线索数据：\n{{steps.data_clean_1.output}}\n\n请以JSON格式返回，包含lead_id和score字段。",
          "model": "deepseek-chat",
          "variables": {
            "rules": "{{steps.knowledge_retrieval_1.output}}",
            "leads": "{{steps.data_clean_1.output}}"
          }
        }
      },
      {
        "id": "budget_split_1",
        "type": "ifelse",
        "config": {
          "name": "预算阈值分流",
          "cases": [
            {
              "id": "high_budget",
              "condition": "{{item.budget >= inputs.budget_threshold}}"
            },
            {
              "id": "low_budget",
              "condition": "{{item.budget < inputs.budget_threshold}}"
            }
          ],
          "variables": {
            "item": "{{steps.llm_scoring_1.output}}"
          }
        }
      },
      {
        "id": "vip_assignment_1",
        "type": "tool",
        "config": {
          "name": "VIP专线手动指派",
          "method": "post",
          "url": "http://example.com/api/vip-assignment",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "leads": "{{steps.budget_split_1.output.high_budget}}",
            "rules": "{{steps.input_check_1.output.vip_assignment_rules}}"
          },
          "variables": {
            "high_budget_leads": "{{steps.budget_split_1.output.high_budget}}",
            "rules": "{{steps.input_check_1.output.vip_assignment_rules}}"
          }
        }
      },
      {
        "id": "public_pool_match_1",
        "type": "tool",
        "config": {
          "name": "公海池自动匹配",
          "method": "post",
          "url": "http://example.com/api/public-pool-match",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "leads": "{{steps.budget_split_1.output.low_budget}}",
            "rules": "{{steps.input_check_1.output.public_pool_matching_rules}}"
          },
          "variables": {
            "low_budget_leads": "{{steps.budget_split_1.output.low_budget}}",
            "rules": "{{steps.input_check_1.output.public_pool_matching_rules}}"
          }
        }
      },
      {
        "id": "aggregator_1",
        "type": "variable_aggregator",
        "config": {
          "name": "分流结果聚合",
          "variables": {
            "vip_assigned": "{{steps.vip_assignment_1.output}}",
            "public_matched": "{{steps.public_pool_match_1.output}}"
          }
        }
      },
      {
        "id": "timeout_check_1",
        "type": "code",
        "config": {
          "name": "销售跟进超时检查",
          "language": "python",
          "script": "import pandas as pd\nfrom datetime import datetime, timedelta\ndef main(assigned_leads, timeout_hours):\n    df = pd.DataFrame(assigned_leads)\n    timeout_hours = int(timeout_hours) if timeout_hours else 72\n    now = datetime.now()\n    # 假设有assign_time字段\n    df['assign_time'] = pd.to_datetime(df.get('assign_time', now))\n    df['is_timeout'] = (now - df['assign_time']) > timedelta(hours=timeout_hours)\n    timeout_leads = df[df['is_timeout']].to_dict('records')\n    return {'timeout_leads': timeout_leads, 'total_count': len(timeout_leads)}",
          "example_key": "parse_json",
          "variables": {
            "assigned_leads": "{{steps.aggregator_1.output}}",
            "timeout_hours": "{{steps.input_check_1.output.timeout_duration}}"
          }
        }
      },
      {
        "id": "first_contact_judge_1",
        "type": "ifelse",
        "config": {
          "name": "首次触达结果判断",
          "cases": [
            {
              "id": "opportunity",
              "condition": "{{item.outcome == '商机'}}"
            },
            {
              "id": "lost",
              "condition": "{{item.outcome == '战败'}}"
            },
            {
              "id": "nurture",
              "condition": "{{item.outcome == '孵化'}}"
            }
          ],
          "variables": {
            "item": "{{steps.timeout_check_1.output}}"
          }
        }
      },
      {
        "id": "report_generation_1",
        "type": "llm",
        "config": {
          "name": "全流程分析报告生成",
          "prompt": "请基于以下全流程数据生成一份分析总结报告：\n1. 清洗并评分后的线索清单：{{steps.llm_scoring_1.output}}\n2. VIP专线指派记录：{{steps.vip_assignment_1.output}}\n3. 公海池分发匹配记录：{{steps.public_pool_match_1.output}}\n4. 销售超时预警报告：{{steps.timeout_check_1.output}}\n5. 转化商机列表：{{steps.first_contact_judge_1.output.opportunity}}\n6. 战败线索归档报告：{{steps.first_contact_judge_1.output.lost}}\n7. 转入孵化培育线索列表：{{steps.first_contact_judge_1.output.nurture}}\n\n报告需包含关键指标、问题分析和改进建议。",
          "model": "deepseek-chat",
          "variables": {
            "scored_leads": "{{steps.llm_scoring_1.output}}",
            "vip_records": "{{steps.vip_assignment_1.output}}",
            "public_records": "{{steps.public_pool_match_1.output}}",
            "timeout_report": "{{steps.timeout_check_1.output}}",
            "opportunities": "{{steps.first_contact_judge_1.output.opportunity}}",
            "lost_leads": "{{steps.first_contact_judge_1.output.lost}}",
            "nurture_leads": "{{steps.first_contact_judge_1.output.nurture}}"
          }
        }
      },
      {
        "id": "answer_1",
        "type": "answer",
        "config": {
          "name": "输出结果",
          "variables": {
            "cleaned_scored_leads": "{{steps.llm_scoring_1.output}}",
            "vip_assignment_records": "{{steps.vip_assignment_1.output}}",
