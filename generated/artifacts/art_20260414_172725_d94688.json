      {
        "id": "code_timeout_check_8",
        "type": "code",
        "config": {
          "name": "超时预警检查",
          "language": "python",
          "script": "import datetime\nfrom datetime import timedelta\n\ndef check_timeout(assigned_leads, threshold_hours):\n    now = datetime.datetime.now()\n    threshold = int(threshold_hours) if threshold_hours else 72\n    \n    timeout_leads = []\n    for lead in assigned_leads:\n        if 'assigned_at' in lead:\n            assigned_time = datetime.datetime.fromisoformat(lead['assigned_at'])\n            time_diff = (now - assigned_time).total_seconds() / 3600\n            \n            if time_diff >= threshold:\n                lead['timeout_hours'] = time_diff\n                lead['check_time'] = now.isoformat()\n                timeout_leads.append(lead)\n    \n    return timeout_leads\n\n# 合并所有已分配线索\nall_assigned = []\nif 'vip_assigned' in inputs:\n    all_assigned.extend(inputs.get('vip_assigned', []))\nif 'public_assigned' in inputs:\n    all_assigned.extend(inputs.get('public_assigned', []))\n\nthreshold = inputs.get('timeout_threshold_hours', '72')\ntimeout_list = check_timeout(all_assigned, threshold)\n\noutputs['timeout_leads'] = timeout_list\noutputs['timeout_count'] = len(timeout_list)\noutputs['check_timestamp'] = datetime.datetime.now().isoformat()",
          "example_key": "parse_json",
          "variables": {
            "vip_assigned": "{{steps.tool_vip_assign_6.outputs}}",
            "public_assigned": "{{steps.tool_public_pool_7.outputs}}",
            "timeout_threshold_hours": "{{inputs.timeout_threshold_hours}}"
          },
          "error_strategy": "fail-branch"
        }
      },
