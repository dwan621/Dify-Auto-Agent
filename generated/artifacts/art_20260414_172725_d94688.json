        "id": "code_format_report_11",
        "type": "code",
        "config": {
          "name": "生成分析报告",
          "language": "python",
          "script": "import json\nfrom datetime import datetime\n\ndef generate_report(aggregated_data):\n    report = {\n        \"report_id\": f\"report_{datetime.now().strftime('%Y%m%d_%H%M%S')}\",\n        \"generated_at\": datetime.now().isoformat(),\n        \"summary\": {\n            \"total_leads_processed\": len(aggregated_data.get('cleaned_data', [])),\n            \"vip_assigned_count\": len(aggregated_data.get('vip_records', {}).get('assigned', [])),\n            \"public_assigned_count\": len(aggregated_data.get('public_records', {}).get('assigned', [])),\n            \"timeout_alerts\": aggregated_data.get('timeout_records', {}).get('timeout_count', 0),\n            \"opportunities_count\": len(aggregated_data.get('followup_analysis', {}).get('opportunities', [])),\n            \"lost_leads_count\": len(aggregated_data.get('followup_analysis', {}).get('lost_leads', [])),\n            \"nurturing_leads_count\": len(aggregated_data.get('followup_analysis', {}).get('nurturing_leads', []))\n        },\n        \"detailed_sections\": {\n            \"cleaning_summary\": aggregated_data.get('cleaned_data', []),\n            \"scoring_summary\": aggregated_data.get('scoring_report', []),\n            \"distribution_summary\": {\n                \"vip_assignment\": aggregated_data.get('vip_records', {}),\n                \"public_pool\": aggregated_data.get('public_records', {})\n            },\n            \"followup_results\": aggregated_data.get('followup_analysis', {})\n        },\n        \"recommendations\": [\n            \"优化高评分线索的跟进策略\",\n            \"加强超时线索的二次触达\",\n            \"定期更新培育线索池\"\n        ]\n    }\n    \n    return json.dumps(report, ensure_ascii=False, indent=2)\n\nfull_report = generate_report(inputs)\noutputs['analysis_report'] = full_report\noutputs['opportunities_list'] = inputs.get('followup_analysis', {}).get('opportunities', [])\noutputs['lost_leads_report'] = inputs.get('followup_analysis', {}).get('lost_leads', [])\noutputs['nurturing_pool'] = inputs.get('followup_analysis', {}).get('nurturing_leads', [])",
