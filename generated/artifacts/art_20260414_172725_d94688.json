      {
        "id": "code_clean_2",
        "type": "code",
        "config": {
          "name": "数据清洗与格式化",
          "language": "python",
          "script": "import pandas as pd\nimport json\n\ndef clean_leads_data(raw_data):\n    # 读取原始数据\n    df = pd.read_csv(raw_data)\n    \n    # 去重\n    df = df.drop_duplicates(subset=['phone', 'email'], keep='first')\n    \n    # 标准化字段\n    df['phone'] = df['phone'].astype(str).str.replace('[^0-9]', '', regex=True)\n    df['email'] = df['email'].astype(str).str.lower()\n    \n    # 处理缺失值\n    df['company'] = df['company'].fillna('未知')\n    df['industry'] = df['industry'].fillna('其他')\n    \n    # 添加清洗标记\n    df['cleaned_at'] = pd.Timestamp.now().isoformat()\n    df['cleaned_status'] = 'success'\n    \n    return df.to_dict('records')\n\ncleaned_data = clean_leads_data(inputs['raw_leads_data'])\noutputs['cleaned_leads'] = cleaned_data\noutputs['cleaned_count'] = len(cleaned_data)",
          "example_key": "clean_text",
          "variables": {
            "raw_leads_data": "{{inputs.raw_leads_data}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "llm_score_3",
        "type": "llm",
        "config": {
          "name": "线索智能评分",
          "prompt": "基于以下评分规则，对清洗后的线索数据进行智能评分：\n\n评分规则：{{inputs.scoring_criteria}}\n\n线索数据：{{steps.code_clean_2.outputs.cleaned_leads}}\n\n请为每条线索生成综合评分（0-100分），并说明评分依据。输出格式为JSON数组，每条记录包含：id, name, company, score, score_reason, score_timestamp。",
          "model": "deepseek-chat",
          "temperature": 0.1,
          "variables": {
            "scoring_criteria": "{{inputs.scoring_criteria}}",
            "cleaned_leads": "{{steps.code_clean_2.outputs.cleaned_leads}}"
          }
        }
      },
      {
        "id": "knowledge_retrieval_4",
        "type": "knowledge_retrieval",
        "config": {
          "name": "检索VIP客户历史记录",
          "query": "VIP客户识别规则和历史分配记录",
          "top_k": 5,
          "score_threshold": 0.7,
          "variables": {
            "cleaned_leads": "{{steps.code_clean_2.outputs.cleaned_leads}}"
          }
        }
      },
      {
        "id": "ifelse_budget_5",
        "type": "ifelse",
        "config": {
          "name": "预算阈值分流",
          "condition": "{{inputs.budget_threshold}}",
          "cases": [
            {
              "id": "high_budget",
              "condition": "score >= 80 and budget >= threshold",
              "name": "高预算高评分"
            },
            {
              "id": "medium_budget",
              "condition": "score >= 60 and budget < threshold",
              "name": "中预算中评分"
            },
            {
              "id": "low_budget",
              "condition": "score < 60",
              "name": "低评分"
            }
          ],
          "variables": {
            "scored_leads": "{{steps.llm_score_3.outputs}}",
            "threshold": "{{inputs.budget_threshold}}"
          }
        }
      },
