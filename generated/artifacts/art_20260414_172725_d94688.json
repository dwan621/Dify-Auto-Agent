        "id": "llm_followup_analysis_9",
        "type": "llm",
        "config": {
          "name": "跟进结果分析",
          "prompt": "分析销售跟进结果反馈，判断线索状态：\n\n跟进反馈：{{inputs.follow_up_result}}\n\n线索数据：{{steps.code_timeout_check_8.outputs.timeout_leads}}\n\n请将线索分为三类：\n1. 正式商机 - 客户明确有意向，可进入商机流程\n2. 战败归档 - 客户明确拒绝或无需求\n3. 长期孵化 - 客户暂时无需求但可保持联系\n\n输出JSON格式，包含三个数组：opportunities, lost_leads, nurturing_leads",
          "model": "deepseek-chat",
          "temperature": 0.2,
          "variables": {
