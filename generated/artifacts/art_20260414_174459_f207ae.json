    "steps": [
      {
        "id": "start",
        "type": "start",
        "config": {}
      },
      {
        "id": "input_check",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import json\nimport sys\n\ndef main(inputs):\n    raw_leads = inputs.get('raw_leads_data')\n    budget = inputs.get('budget_threshold')\n    \n    if not raw_leads:\n        return {'status': 'error', 'message': '原始线索数据为必填项'}\n    \n    try:\n        budget_val = float(budget) if budget else 0\n    except:\n        return {'status': 'error', 'message': '预算分流阈值需为数字'}\n    \n    return {'status': 'success', 'raw_leads': raw_leads, 'budget_threshold': budget_val}",
          "example_key": "parse_json",
          "variables": {
            "raw_leads_data": "{{inputs.raw_leads_data}}",
            "budget_threshold": "{{inputs.budget_threshold}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_cleaner",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import pandas as pd\nimport json\n\ndef main(inputs):\n    raw_data = inputs.get('raw_leads')\n    \n    # 模拟数据清洗\n    df = pd.DataFrame(raw_data)\n    \n    # 去重、填充缺失值、格式化字段\n    df_clean = df.drop_duplicates(subset=['email', 'phone'])\n    df_clean['company'] = df_clean['company'].fillna('未知')\n    df_clean['industry'] = df_clean['industry'].fillna('其他')\n    \n    cleaned_list = df_clean.to_dict('records')\n    return {'cleaned_leads': cleaned_list}",
          "example_key": "clean_text",
          "variables": {
            "raw_leads": "{{steps.input_check.output.raw_leads}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "lead_scoring",
        "type": "llm",
        "config": {
          "prompt": "你是一个线索评分专家。请根据以下线索信息和评分规则，为每条线索计算综合得分（0-100分）。\n\n线索数据：{{steps.data_cleaner.output.cleaned_leads}}\n\n评分规则：{{inputs.scoring_criteria}}\n\n来源优先级：{{inputs.source_priority_list}}\n\n请输出JSON格式：{\"scored_leads\": [{\"id\": 1, \"name\": \"xxx\", \"score\": 85, \"level\": \"A\"}, ...]}，其中level根据分数划分：A(>=80), B(60-79), C(<60)",
          "variables": {
            "cleaned_leads": "{{steps.data_cleaner.output.cleaned_leads}}",
            "scoring_criteria": "{{inputs.scoring_criteria}}",
            "source_priority_list": "{{inputs.source_priority_list}}"
          },
          "model": "deepseek-chat"
        }
      },
      {
        "id": "budget_split",
        "type": "ifelse",
        "config": {
          "condition": "{{steps.lead_scoring.output.scored_leads}}",
          "cases": [
            {
              "id": "vip",
              "name": "VIP线索",
              "condition": "item.score >= 90"
            },
            {
              "id": "high",
              "name": "高预算线索",
              "condition": "item.score >= 70 and item.budget >= {{steps.input_check.output.budget_threshold}}"
            },
            {
              "id": "public",
              "name": "公海池线索",
              "condition": "true"
            }
          ]
        }
      },
      {
        "id": "vip_assignment",
        "type": "tool",
        "config": {
          "method": "post",
          "url": "http://example.com/api/vip-assign",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "leads": "{{steps.lead_scoring.output.scored_leads}}",
            "type": "vip"
          },
          "variables": {
            "scored_leads": "{{steps.lead_scoring.output.scored_leads}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "public_distribution",
        "type": "tool",
        "config": {
          "method": "post",
          "url": "http://example.com/api/public-distribute",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "leads": "{{steps.lead_scoring.output.scored_leads}}",
            "type": "public"
          },
          "variables": {
            "scored_leads": "{{steps.lead_scoring.output.scored_leads}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "aggregate_distribution",
        "type": "variable_aggregator",
        "config": {
          "variables": {
            "vip_log": "{{steps.vip_assignment.output}}",
            "public_log": "{{steps.public_distribution.output}}"
          }
        }
      },
      {
        "id": "followup_monitor",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import datetime\nimport json\n\ndef main(inputs):\n    distribution_log = inputs.get('distribution_log')\n    timeout_hours = inputs.get('timeout_duration', 24)\n    \n    alerts = []\n    current_time = datetime.datetime.now()\n    \n    for lead in distribution_log.get('assigned_leads', []):\n        assign_time = datetime.datetime.fromisoformat(lead['assign_time'])\n        time_diff = (current_time - assign_time).total_seconds() / 3600\n        \n        if time_diff > timeout_hours and not lead.get('contacted'):\n            alerts.append({\n                'lead_id': lead['id'],\n                'sales_rep': lead['sales_rep'],\n                'assign_time': lead['assign_time'],\n                'timeout_hours': round(time_diff, 1)\n            })\n    \n    return {'timeout_alerts': alerts}",
          "example_key": "parse_json",
          "variables": {
            "distribution_log": "{{steps.aggregate_distribution.output}}",
            "timeout_duration": "{{inputs.timeout_duration}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "first_contact",
        "type": "llm",
        "config": {
          "prompt": "销售代表已完成首次触达。请根据以下触达记录，分析触达结果并分类：\n\n触达记录：{{steps.followup_monitor.output.contact_records}}\n\n请输出JSON格式：{\"first_contact_results\": {\"interested\": [...], \"needs_nurturing\": [...], \"not_interested\": [...]}}",
          "variables": {
            "contact_records": "{{steps.followup_monitor.output.contact_records}}"
          },
          "model": "deepseek-chat"
        }
      },
      {
        "id": "opportunity_check",
        "type": "ifelse",
        "config": {
          "condition": "{{steps.first_contact.output.first_contact_results}}",
          "cases": [
            {
              "id": "convert",
              "name": "转化商机",
              "condition": "item.status == 'interested' and item.budget >= {{steps.input_check.output.budget_threshold}}"
            },
            {
              "id": "nurture",
              "name": "培育孵化",
              "condition": "item.status == 'needs_nurturing'"
            },
            {
              "id": "defeat",
              "name": "标记战败",
              "condition": "item.status == 'not_interested'"
            }
          ]
        }
      },
      {
        "id": "generate_report",
        "type": "template",
        "config": {
          "template": "# 市场活动线索全生命周期管理报告\n\n## 执行概览\n- 处理线索总数：{{total_leads}}\n- 清洗后线索数：{{cleaned_count}}\n- VIP线索数：{{vip_count}}\n- 公海池分发数：{{public_count}}\n\n## 评分分布\n{{scoring_summary}}\n\n## 跟进情况\n- 超时预警：{{timeout_alerts_count}}条\n- 首次触达成功率：{{first_contact_rate}}%\n\n## 转化结果\n- 正式商机：{{opportunity_count}}个\n- 战败归档：{{defeated_count}}个\n- 培育孵化：{{nurturing_count}}个\n\n## 建议与优化\n{{recommendations}}",
          "variables": {
            "total_leads": "{{steps.data_cleaner.output.total_count}}",
            "cleaned_count": "{{steps.data_cleaner.output.cleaned_count}}",
            "vip_count": "{{steps.vip_assignment.output.assigned_count}}",
            "public_count": "{{steps.public_distribution.output.distributed_count}}",
            "scoring_summary": "{{steps.lead_scoring.output.summary}}",
            "timeout_alerts_count": "{{steps.followup_monitor.output.alerts_count}}",
            "first_contact_rate": "{{steps.first_contact.output.success_rate}}",
            "opportunity_count": "{{steps.opportunity_check.output.convert_count}}",
            "defeated_count": "{{steps.opportunity_check.output.defeat_count}}",
            "nurturing_count": "{{steps.opportunity_check.output.nurture_count}}",
            "recommendations": "{{steps.llm_optimization.output.recommendations}}"
          }
        }
      },
      {
