    "steps": [
      {
        "id": "start",
        "type": "start",
        "config": {
          "name": "开始",
          "description": "启动数据处理流程"
        }
      },
      {
        "id": "ftp_download",
        "type": "tool",
        "config": {
          "name": "FTP文件下载",
          "description": "从FTP服务器下载CSV日志文件",
          "method": "get",
          "url": "https://httpbin.org/get",
          "headers": {},
          "body": {},
          "variables": {
            "ftp_config": "{{inputs.ftp_config}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_cleaning",
        "type": "code",
        "config": {
          "name": "数据清洗转换",
          "description": "清洗CSV数据，处理缺失值和格式转换",
          "language": "python",
          "script": "import pandas as pd\nimport json\n\ndef clean_data(csv_content):\n    # 读取CSV数据\n    df = pd.read_csv(pd.compat.StringIO(csv_content))\n    \n    # 清洗操作\n    df = df.dropna(subset=['user_id', 'timestamp'])  # 删除关键字段缺失的行\n    df['timestamp'] = pd.to_datetime(df['timestamp'], errors='coerce')\n    df = df.dropna(subset=['timestamp'])  # 删除时间格式错误行\n    \n    # 标准化文本字段\n    if 'action' in df.columns:\n        df['action'] = df['action'].str.strip().str.lower()\n    \n    # 返回清洗后的数据\n    return df.to_dict(orient='records'), len(df)\n\n# 执行清洗\ncleaned_data, record_count = clean_data(input_data)\noutput = {\n    'cleaned_data': cleaned_data,\n    'record_count': record_count,\n    'status': 'success'\n}",
          "example_key": "clean_text",
          "variables": {
            "input_data": "{{steps.ftp_download.output.body}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "geo_enrichment",
        "type": "tool",
        "config": {
          "name": "地理位置信息补全",
          "description": "调用地理位置API补全IP地址信息",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": "",
          "body": {
            "ip_addresses": "{{steps.data_cleaning.output.cleaned_data | map(attribute='ip') | list}}"
          },
          "variables": {
            "api_key": "{{inputs.api_key}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_validation",
        "type": "ifelse",
        "config": {
          "name": "数据质量检查",
          "description": "检查清洗后的数据质量是否达标",
          "condition": "{{steps.data_cleaning.output.record_count > 0 and steps.data_cleaning.output.status == 'success'}}",
          "cases": [
            {
              "id": "quality_pass",
              "name": "质量达标",
              "condition": "true"
            },
            {
              "id": "quality_fail",
              "name": "质量不达标",
              "condition": "false"
            }
          ]
        }
      },
      {
        "id": "risk_analysis",
        "type": "llm",
        "config": {
          "name": "业务风险分析",
          "description": "分析数据中的高风险操作和异常模式",
          "prompt": "分析以下日志数据，识别高风险操作和异常模式：\n\n数据记录数：{{steps.data_cleaning.output.record_count}}\n清洗后数据：{{steps.data_cleaning.output.cleaned_data | tojson}}\n地理位置信息：{{steps.geo_enrichment.output | tojson}}\n\n请分析：\n1. 高风险操作数量（如登录失败、权限变更等）\n2. 异常访问模式（如短时间内多次访问）\n3. 地理位置异常（如异地登录）\n4. 生成风险报告摘要",
          "model": "deepseek-chat",
          "variables": {}
        }
      },
      {
        "id": "report_generation",
        "type": "template",
        "config": {
          "name": "报表生成",
          "description": "生成每日处理报告",
          "template": "## 自动化数据处理报告\n\n### 执行概览\n- 处理时间：{{timestamp}}\n- 数据记录数：{{steps.data_cleaning.output.record_count}}\n- 清洗状态：{{steps.data_cleaning.output.status}}\n\n### 风险分析结果\n{{steps.risk_analysis.output}}\n\n### 地理位置补全\n- 补全记录数：{{steps.geo_enrichment.output.enriched_count | default(0)}}\n- 成功率：{{steps.geo_enrichment.output.success_rate | default('N/A')}}\n\n### 系统状态\n- 数据库连接：{{inputs.db_connection | truncate(20)}}\n- 监控平台：{{inputs.monitoring_platform_url}}\n\n---\n*报告生成时间：{{timestamp}}*",
          "variables": {
            "timestamp": "{{now()}}"
          }
        }
      },
      {
        "id": "aggregate_results",
        "type": "variable_aggregator",
        "config": {
          "name": "结果汇总",
          "description": "汇总各分支执行结果",
          "variables": {
            "data_quality_status": "{{steps.data_validation.output.selected_case}}",
            "cleaned_record_count": "{{steps.data_cleaning.output.record_count}}",
            "risk_analysis_result": "{{steps.risk_analysis.output}}",
            "report_content": "{{steps.report_generation.output}}",
            "geo_enrichment_status": "{{steps.geo_enrichment.output.status}}",
            "ftp_download_status": "{{steps.ftp_download.output.status}}"
          }
        }
      },
      {
        "id": "final_answer",
        "type": "answer",
        "config": {
          "name": "最终输出",
          "description": "输出处理结果汇总报告"
        }
      },
