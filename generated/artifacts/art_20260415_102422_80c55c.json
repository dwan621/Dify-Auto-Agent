    "steps": [
      {
        "id": "start",
        "type": "start",
        "config": {
          "name": "开始",
          "description": "启动数据处理工作流"
        }
      },
      {
        "id": "ftp_data_fetch",
        "type": "tool",
        "config": {
          "name": "FTP数据获取",
          "description": "从FTP服务器读取CSV日志文件",
          "method": "get",
          "url": "https://httpbin.org/get",
          "headers": {},
          "body": {},
          "variables": {
            "ftp_config": "{{inputs.ftp_config}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_cleaning",
        "type": "code",
        "config": {
          "name": "数据清洗转换",
          "description": "清洗CSV数据，去除无效记录，格式化字段",
          "language": "python",
          "script": "def clean_data(raw_data):\n    # 数据清洗逻辑\n    cleaned = []\n    for record in raw_data:\n        if record.get('valid') and record.get('timestamp'):\n            cleaned.append({\n                'id': record.get('id'),\n                'timestamp': record['timestamp'],\n                'operation': record.get('operation', '').strip(),\n                'user_id': record.get('user_id'),\n                'ip_address': record.get('ip_address'),\n                'location': record.get('location', '')\n            })\n    return cleaned",
          "example_key": "clean_text",
          "variables": {
            "raw_data": "{{steps.ftp_data_fetch.output.data}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "geo_enrichment",
        "type": "tool",
        "config": {
          "name": "地理位置信息补全",
          "description": "调用外部API补全IP地址的地理位置信息",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": "",
          "body": {
            "ip_addresses": "{{steps.data_cleaning.output.cleaned_data}}"
          },
          "variables": {},
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_persistence",
        "type": "code",
        "config": {
          "name": "数据入库",
          "description": "将处理后的数据写入云数据库",
          "language": "python",
          "script": "def persist_data(enriched_data, db_conn):\n    import json\n    # 模拟数据库写入\n    success_count = 0\n    for record in enriched_data:\n        try:\n            # 数据库插入逻辑\n            success_count += 1\n        except Exception as e:\n            print(f\"Failed to insert record: {e}\")\n    return {\n        'inserted_count': success_count,\n        'total_records': len(enriched_data)\n    }",
          "example_key": "parse_json",
          "variables": {
            "enriched_data": "{{steps.geo_enrichment.output.enriched_data}}",
            "db_connection": "{{inputs.db_connection}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "risk_analysis",
        "type": "ifelse",
        "config": {
          "name": "业务规则判断",
          "description": "根据规则判断高风险操作",
          "condition": "{{steps.data_persistence.output.inserted_count}} > 0",
          "cases": [
            {
              "id": "high_risk_detected",
              "condition": "{{steps.data_cleaning.output.cleaned_data | length}} > 100",
              "name": "检测到高风险"
            },
            {
              "id": "normal_operation",
              "condition": "true",
              "name": "正常操作"
            }
          ]
        }
      },
      {
        "id": "alert_trigger",
        "type": "tool",
        "config": {
          "name": "告警触发",
          "description": "向监控平台发送告警信息",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "alert_type": "high_risk_operation",
            "count": "{{steps.risk_analysis.output.high_risk_count}}",
            "timestamp": "{{system.timestamp}}"
          },
          "variables": {},
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "report_generation",
        "type": "llm",
        "config": {
          "name": "报表生成",
          "description": "生成数据处理统计报表",
          "prompt": "基于以下数据处理结果生成统计报表：\n- 原始记录数: {{steps.ftp_data_fetch.output.record_count}}\n- 清洗后记录数: {{steps.data_cleaning.output.cleaned_count}}\n- 成功入库数: {{steps.data_persistence.output.inserted_count}}\n- 高风险操作数: {{steps.risk_analysis.output.high_risk_count}}\n- 告警触发数: {{steps.alert_trigger.output.alert_count}}\n\n请生成结构化的报表，包含摘要、详细统计和执行建议。",
          "variables": {
            "record_count": "{{steps.ftp_data_fetch.output.record_count}}",
            "cleaned_count": "{{steps.data_cleaning.output.cleaned_count}}",
            "inserted_count": "{{steps.data_persistence.output.inserted_count}}",
            "high_risk_count": "{{steps.risk_analysis.output.high_risk_count}}",
            "alert_count": "{{steps.alert_trigger.output.alert_count}}"
          }
        }
      },
      {
        "id": "aggregator",
        "type": "variable_aggregator",
        "config": {
          "name": "执行结果汇总",
          "description": "汇总各分支执行结果",
          "variables": {
            "final_status": "{{steps.report_generation.output.status}}",
            "processed_records_count": "{{steps.data_persistence.output.inserted_count}}",
            "cleaned_records_count": "{{steps.data_cleaning.output.cleaned_count}}",
            "high_risk_operations_detected": "{{steps.risk_analysis.output.high_risk_count}}",
            "alerts_triggered": "{{steps.alert_trigger.output.alert_count}}",
            "report_generated": "{{steps.report_generation.output.report_path}}",
            "execution_log_summary": "{{system.execution_log}}",
            "error_logs": "{{system.error_logs}}",
            "next_scheduled_time": "{{system.next_scheduled_time}}"
          }
        }
      },
