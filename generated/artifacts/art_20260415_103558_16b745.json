        "required": true
      }
    ],
    "output_contract": {
      "summary_report": "最终生成的统计报表文件或链接",
      "execution_log": "包含各节点状态、时间戳和错误信息的详细执行日志",
      "final_status": "流程最终执行状态（成功/失败/部分成功）",
      "alert_triggered": "布尔值，指示高风险告警是否被触发"
    },
    "steps": [
      {
        "id": "start",
        "type": "start",
        "config": {
          "name": "开始"
        }
      },
      {
        "id": "ftp_download",
        "type": "tool",
        "config": {
          "name": "FTP文件下载",
          "method": "get",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "action": "download_csv",
            "ftp_config": "{{ftp_config}}"
          },
          "variables": {
            "ftp_config": "inputs.ftp_config"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_cleaning",
        "type": "code",
        "config": {
          "name": "数据清洗转换",
          "language": "python",
          "script": "import pandas as pd\nimport json\n\ndef clean_data(raw_data):\n    # 解析CSV数据\n    df = pd.read_csv(pd.compat.StringIO(raw_data))\n    \n    # 清洗操作\n    df = df.dropna()\n    df = df.drop_duplicates()\n    df['timestamp'] = pd.to_datetime(df['timestamp'])\n    \n    # 格式标准化\n    df['amount'] = df['amount'].astype(float)\n    df['user_id'] = df['user_id'].astype(str)\n    \n    return df.to_json(orient='records')\n\nresult = clean_data(input_data)",
          "example_key": "clean_text",
          "variables": {
            "input_data": "steps.ftp_download.output"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "geo_enrichment",
        "type": "tool",
        "config": {
          "name": "地理位置信息补全",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": "",
          "body": {
            "data": "{{cleaned_data}}",
            "enrich_fields": [
              "ip_address",
              "city",
              "country"
            ]
          },
          "variables": {
            "api_key": "inputs.api_key",
            "cleaned_data": "steps.data_cleaning.output"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "db_insert",
        "type": "tool",
        "config": {
          "name": "数据入库",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "db_config": "{{db_config}}",
            "data": "{{enriched_data}}",
            "table": "daily_logs"
          },
          "variables": {
            "db_config": "inputs.db_config",
            "enriched_data": "steps.geo_enrichment.output"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "business_rules",
        "type": "ifelse",
        "config": {
          "name": "业务规则判断",
          "condition": "{{data_quality}} == 'high' and {{anomaly_count}} < 5",
          "cases": [
            {
              "id": "normal",
              "name": "正常流程"
            },
            {
              "id": "alert",
              "name": "触发告警"
            }
          ],
          "variables": {
            "data_quality": "steps.data_quality_check.output.quality_score",
            "anomaly_count": "steps.data_quality_check.output.anomalies_count"
          }
        }
      },
      {
        "id": "data_quality_check",
        "type": "code",
        "config": {
          "name": "数据质量检查",
          "language": "python",
          "script": "import json\n\ndef check_quality(data_json):\n    data = json.loads(data_json)\n    \n    total_records = len(data)\n    if total_records == 0:\n        return {'quality_score': 'low', 'anomalies_count': 0}\n    \n    # 检查字段完整性\n    complete_records = sum(1 for record in data \n                          if all(key in record for key in ['user_id', 'timestamp', 'amount']))\n    completeness = complete_records / total_records\n    \n    # 检查异常值\n    anomalies = 0\n    for record in data:\n        if 'amount' in record and record['amount'] > 1000000:\n            anomalies += 1\n    \n    # 计算质量分数\n    if completeness > 0.95 and anomalies / total_records < 0.01:\n        quality = 'high'\n    elif completeness > 0.8:\n        quality = 'medium'\n    else:\n        quality = 'low'\n    \n    return {'quality_score': quality, 'anomalies_count': anomalies}\n\nresult = check_quality(input_data)",
          "example_key": "parse_json",
          "variables": {
            "input_data": "steps.geo_enrichment.output"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "send_alert",
        "type": "tool",
        "config": {
          "name": "发送告警邮件",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "to": "{{alert_email}}",
            "subject": "高风险数据告警",
            "body": "检测到异常数据，请立即检查"
          },
          "variables": {
            "alert_email": "inputs.alert_email"
          }
        }
      },
      {
        "id": "generate_report",
        "type": "llm",
        "config": {
          "name": "生成统计报表",
          "prompt": "基于以下数据处理结果生成详细的统计报告：\n数据质量检查结果：{{quality_result}}\n地理位置补全状态：{{geo_status}}\n数据库插入记录数：{{insert_count}}\n\n请生成包含以下内容的报告：\n1. 执行概览\n2. 数据质量分析\n3. 处理统计\n4. 建议与改进点",
          "variables": {
            "quality_result": "steps.data_quality_check.output",
            "geo_status": "steps.geo_enrichment.output.status",
            "insert_count": "steps.db_insert.output.inserted_count"
          }
        }
      },
      {
        "id": "aggregate_results",
        "type": "variable_aggregator",
        "config": {
          "name": "结果汇总",
          "variables": {
            "report_content": "steps.generate_report.output",
            "alert_sent": "steps.send_alert.output.success",
            "db_success": "steps.db_insert.output.success",
            "ftp_success": "steps.ftp_download.output.success"
          }
        }
      },
      {
        "id": "upload_to_monitor",
        "type": "tool",
        "config": {
          "name": "回传监控平台",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "monitor_url": "{{monitor_url}}",
            "report": "{{report}}",
            "status": "{{status}}"
          },
          "variables": {
            "monitor_url": "inputs.monitor_platform_url",
            "report": "steps.aggregate_results.variables.report_content",
            "status": "steps.final_status_check.output"
          }
        }
      },
      {
        "id": "final_status_check",
        "type": "code",
        "config": {
          "name": "最终状态检查",
          "language": "python",
          "script": "def check_final_status(aggregated):\n    all_success = aggregated['db_success'] and aggregated['ftp_success']\n    alert_triggered = aggregated.get('alert_sent', False)\n    \n    if not all_success:\n        return '失败'\n    elif alert_triggered:\n        return '部分成功（有告警）'\n    else:\n        return '成功'\n\nresult = check_final_status(aggregated_vars)",
          "example_key": "parse_json",
          "variables": {
            "aggregated_vars": "steps.aggregate_results.variables"
          }
        }
      },
      {
        "id": "answer",
        "type": "answer",
        "config": {
          "name": "输出结果",
          "variables": {
            "summary_report": "steps.generate_report.output",
            "execution_log": "steps.aggregate_results.variables",
            "final_status": "steps.final_status_check.output",
            "alert_triggered": "steps.aggregate_results.variables.alert_sent"
          }
        }
      },
