  "selected_spec": {
    "workflow_name": "自动化数据处理工作流",
    "description": "每日定时处理FTP服务器上的CSV日志文件，包括数据读取、清洗转换、地理位置信息补全、数据入库、业务规则判断、告警触发、报表生成以及执行结果汇总回传",
    "scene": "generic",
    "inputs": [
      {
        "name": "ftp_config",
        "label": "FTP服务器配置",
        "type": "text",
