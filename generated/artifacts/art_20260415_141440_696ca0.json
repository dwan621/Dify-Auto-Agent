        "label": "地理位置API密钥",
        "type": "text",
        "required": true
      },
      {
        "name": "db_config",
        "label": "云数据库连接配置",
        "type": "text",
        "required": true
      },
      {
        "name": "alert_rules",
        "label": "高风险操作告警规则",
        "type": "paragraph",
        "required": false
      },
      {
        "name": "monitor_platform_url",
        "label": "监控平台回传地址",
        "type": "text",
        "required": true
      }
    ],
    "output_contract": {
      "summary_report": "每日数据处理统计报告（JSON格式）",
      "execution_log": "包含各节点状态、时间戳及错误信息的完整执行日志（JSON格式）",
