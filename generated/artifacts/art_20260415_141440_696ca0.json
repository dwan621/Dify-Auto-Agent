      "alert_status": "告警触发状态（触发/未触发）及详情",
      "data_quality_metrics": "数据清洗前后的质量指标对比"
    },
    "steps": [
      {
        "id": "start",
        "type": "start",
        "config": {
          "name": "启动流程",
          "description": "每日凌晨2点触发，初始化流程执行环境"
        }
      },
      {
        "id": "ftp_fetch",
        "type": "tool",
        "config": {
          "name": "从FTP服务器读取CSV日志",
          "description": "根据配置连接到FTP服务器，读取指定格式的CSV日志文件",
          "method": "get",
          "url": "https://httpbin.org/get",
          "headers": {},
          "body": {},
          "variables": {
            "ftp_config": "{{inputs.ftp_config}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_clean",
        "type": "code",
        "config": {
          "name": "数据清洗与转换",
          "description": "处理CSV数据中的空值、异常模式，进行格式标准化",
          "language": "python",
          "script": "def clean_data(raw_data):\n    # 实现数据清洗逻辑：处理空值、异常模式、格式转换\n    # 计算清洗前后的质量指标\n    cleaned_data = raw_data  # 占位符\n    quality_metrics = {\"before\": {}, \"after\": {}}\n    return cleaned_data, quality_metrics",
          "example_key": "clean_text",
          "variables": {
            "raw_data": "{{steps.ftp_fetch.output}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "geo_enrich",
        "type": "tool",
        "config": {
          "name": "补全地理位置信息",
          "description": "调用外部API，根据IP地址补全地理位置信息",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": "",
          "body": {
            "ips": "{{steps.data_clean.output.cleaned_data.ips}}"
          },
          "variables": {
            "api_key": "{{inputs.api_key}}",
            "cleaned_data": "{{steps.data_clean.output.cleaned_data}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "db_persist",
        "type": "code",
        "config": {
          "name": "数据持久化到云数据库",
          "description": "将处理后的数据写入指定的云数据库表",
          "language": "python",
          "script": "def persist_to_db(enriched_data, db_config):\n    # 实现数据库连接与数据插入逻辑\n    # 支持断点续传机制\n    insert_count = len(enriched_data)\n    return {\"inserted_rows\": insert_count, \"status\": \"success\"}",
          "example_key": "parse_json",
          "variables": {
            "enriched_data": "{{steps.geo_enrich.output}}",
            "db_config": "{{inputs.db_config}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "rule_engine",
        "type": "ifelse",
        "config": {
          "name": "业务规则判断引擎",
          "description": "基于预定义规则判断是否需要触发告警",
          "condition": "{{steps.db_persist.output.inserted_rows > 0}}",
          "cases": [
            {
              "id": "high_risk",
              "condition": "{{steps.db_persist.output.inserted_rows > 1000}}",
              "name": "高风险操作检测"
            },
            {
              "id": "normal",
              "condition": "true",
              "name": "正常处理流程"
            }
          ]
        }
      },
      {
        "id": "alert_trigger",
        "type": "tool",
        "config": {
          "name": "触发告警通知",
          "description": "当检测到高风险操作时，触发告警通知到监控平台",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "alert_type": "high_risk_operation",
            "data_count": "{{steps.db_persist.output.inserted_rows}}",
            "timestamp": "{{timestamp}}"
          },
          "variables": {
            "monitor_platform_url": "{{inputs.monitor_platform_url}}",
            "inserted_rows": "{{steps.db_persist.output.inserted_rows}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "report_generate",
        "type": "llm",
        "config": {
          "name": "生成每日统计报告",
          "description": "基于处理结果生成JSON格式的每日统计报告",
          "prompt": "基于以下数据处理结果生成每日统计报告：\n数据清洗质量指标：{{steps.data_clean.output.quality_metrics}}\n地理位置补全状态：{{steps.geo_enrich.output.status}}\n数据库插入行数：{{steps.db_persist.output.inserted_rows}}\n告警规则：{{inputs.alert_rules}}\n\n请生成包含以下内容的JSON报告：\n1. 数据处理统计摘要\n2. 数据质量评估\n3. 执行时间线\n4. 资源使用情况",
          "model": "deepseek-chat",
          "temperature": 0.1
        }
      },
      {
        "id": "aggregate_results",
        "type": "variable_aggregator",
        "config": {
          "name": "执行结果汇总",
          "description": "汇总各分支的执行结果，准备最终输出",
          "variables": {
            "summary_report": "{{steps.report_generate.output}}",
            "execution_log": {
              "ftp_fetch": "{{steps.ftp_fetch.output}}",
              "data_clean": "{{steps.data_clean.output}}",
              "geo_enrich": "{{steps.geo_enrich.output}}",
              "db_persist": "{{steps.db_persist.output}}",
              "rule_engine": "{{steps.rule_engine.output}}",
              "timestamp": "{{timestamp}}"
            },
            "alert_status": {
              "triggered": "{{steps.rule_engine.output.branch == 'high_risk'}}",
              "details": "{{steps.alert_trigger.output}}"
            },
            "data_quality_metrics": "{{steps.data_clean.output.quality_metrics}}"
          }
        }
      },
      {
        "id": "final_answer",
        "type": "answer",
        "config": {
          "name": "输出最终结果",
          "description": "将汇总后的执行结果输出，包含统计报告、执行日志、告警状态和数据质量指标"
        }
