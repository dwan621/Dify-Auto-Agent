    "workflow_name": "自动化数据处理与监控工作流",
    "description": "一个用于自动化处理每日CSV日志文件的完整工作流。它从FTP服务器获取原始数据，进行清洗、转换、地理位置补全，然后写入数据库。根据业务规则判断风险，触发告警或生成报表，最后汇总所有日志和状态回传至监控平台。",
    "scene": "generic",
    "inputs": [
      {
        "name": "ftp_config",
        "label": "FTP服务器配置",
        "type": "text",
        "required": true
      },
      {
        "name": "api_key",
        "label": "地理位置API密钥",
        "type": "text",
        "required": true
      },
      {
        "name": "db_connection",
        "label": "云数据库连接字符串",
        "type": "text",
        "required": true
      },
      {
        "name": "alert_recipients",
        "label": "告警邮件接收人",
        "type": "text",
        "required": false
      },
      {
        "name": "monitoring_webhook",
        "label": "监控平台Webhook地址",
        "type": "text",
        "required": true
      }
    ],
    "output_contract": {
      "final_status": "string (SUCCESS/FAILED)",
      "processed_record_count": "integer",
      "high_risk_alert_triggered": "boolean",
      "report_generated": "boolean",
      "execution_log_summary": "string",
      "timestamp": "string (ISO 8601)"
    },
    "steps": [
      {
        "id": "start",
        "type": "start",
        "config": {}
      },
      {
        "id": "input_validation",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import json\ninputs = json.loads(inputs)\nrequired = ['ftp_config', 'api_key', 'db_connection', 'monitoring_webhook']\nmissing = [r for r in required if not inputs.get(r)]\nif missing:\n    raise ValueError(f'Missing required inputs: {missing}')\nreturn {'valid': True, 'message': 'Input validation passed'}",
          "example_key": "parse_json",
          "variables": {
            "inputs": "{{inputs}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "fetch_csv_from_ftp",
        "type": "tool",
        "config": {
          "method": "get",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "ftp_config": "{{ftp_config}}",
            "action": "fetch_latest_csv"
          },
          "variables": {
            "ftp_config": "{{ftp_config}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "clean_csv_data",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import pandas as pd\nimport json\nraw_data = json.loads(inputs['fetch_csv_from_ftp'])\ncsv_content = raw_data.get('csv_content', '')\n# Simulate cleaning\ndf = pd.read_csv(pd.compat.StringIO(csv_content))\ndf = df.dropna()\ndf = df.drop_duplicates()\ncleaned = df.to_dict('records')\nreturn {'cleaned_data': cleaned, 'record_count': len(cleaned)}",
          "example_key": "clean_text",
          "variables": {
            "fetch_csv_from_ftp": "{{fetch_csv_from_ftp}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "enrich_with_geolocation",
        "type": "tool",
        "config": {
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": "",
          "body": {
            "data": "{{clean_csv_data.cleaned_data}}",
            "api_key": "{{api_key}}"
          },
          "variables": {
            "clean_csv_data.cleaned_data": "{{clean_csv_data.cleaned_data}}",
            "api_key": "{{api_key}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "write_to_database",
        "type": "tool",
        "config": {
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "db_connection": "{{db_connection}}",
            "data": "{{enrich_with_geolocation}}"
          },
          "variables": {
            "db_connection": "{{db_connection}}",
            "enrich_with_geolocation": "{{enrich_with_geolocation}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "risk_assessment",
        "type": "ifelse",
        "config": {
          "cases": [
            {
              "id": "high_risk",
              "condition": "{{write_to_database.record_count}} > 1000 or {{write_to_database.has_anomaly}} == true"
            },
            {
              "id": "normal",
              "condition": "default"
            }
          ]
        }
      },
      {
        "id": "trigger_alert",
        "type": "llm",
        "config": {
          "prompt": "Generate an alert email for high-risk situation. Processed records: {{write_to_database.record_count}}. Recipients: {{alert_recipients}}. Include timestamp and summary.",
          "variables": {
            "write_to_database.record_count": "{{write_to_database.record_count}}",
            "alert_recipients": "{{alert_recipients}}"
          }
        }
      },
      {
        "id": "generate_report",
        "type": "llm",
        "config": {
          "prompt": "Generate a daily processing report. Records processed: {{write_to_database.record_count}}. Status: normal. Include summary and recommendations.",
          "variables": {
            "write_to_database.record_count": "{{write_to_database.record_count}}"
          }
        }
      },
      {
        "id": "aggregate_results",
        "type": "variable_aggregator",
        "config": {
          "variables": {
            "processed_record_count": "{{write_to_database.record_count}}",
            "high_risk_alert_triggered": "{{risk_assessment.branch == 'high_risk'}}",
            "report_generated": "true",
            "execution_log_summary": "Daily CSV processing completed with {{write_to_database.record_count}} records."
          }
        }
      },
      {
        "id": "send_to_monitoring",
        "type": "tool",
        "config": {
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "final_status": "SUCCESS",
            "processed_record_count": "{{aggregate_results.processed_record_count}}",
            "high_risk_alert_triggered": "{{aggregate_results.high_risk_alert_triggered}}",
            "report_generated": "{{aggregate_results.report_generated}}",
            "execution_log_summary": "{{aggregate_results.execution_log_summary}}",
            "timestamp": "{{timestamp}}"
          },
          "variables": {
            "monitoring_webhook": "{{monitoring_webhook}}",
            "aggregate_results.processed_record_count": "{{aggregate_results.processed_record_count}}",
            "aggregate_results.high_risk_alert_triggered": "{{aggregate_results.high_risk_alert_triggered}}",
            "aggregate_results.report_generated": "{{aggregate_results.report_generated}}",
            "aggregate_results.execution_log_summary": "{{aggregate_results.execution_log_summary}}",
            "timestamp": "{{timestamp}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "answer",
        "type": "answer",
        "config": {
          "answer": "Workflow completed. Final status: SUCCESS. Processed {{aggregate_results.processed_record_count}} records. High risk alert triggered: {{aggregate_results.high_risk_alert_triggered}}. Report generated: {{aggregate_results.report_generated}}."
        }
