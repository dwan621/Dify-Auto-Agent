    },
    "steps": [
      {
        "id": "start",
        "type": "start",
        "config": {
          "name": "开始",
          "description": "流程开始节点，接收输入参数"
        }
      },
      {
        "id": "ftp_download",
        "type": "tool",
        "config": {
          "name": "FTP文件下载",
          "description": "从FTP服务器下载CSV日志文件",
          "method": "get",
          "url": "https://httpbin.org/get",
          "headers": {},
          "body": null,
          "variables": {
            "ftp_config": "{{inputs.ftp_config}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_clean",
        "type": "code",
        "config": {
          "name": "数据清洗转换",
          "description": "清洗CSV数据，处理缺失值和格式转换",
          "language": "python",
          "script": "import pandas as pd\nimport json\n\ndef process(data):\n    df = pd.read_csv(data['file_path'])\n    df = df.dropna()\n    df['timestamp'] = pd.to_datetime(df['timestamp'])\n    return {'cleaned_data': df.to_dict('records'), 'row_count': len(df)}",
          "example_key": "clean_text",
          "variables": {
            "file_path": "{{steps.ftp_download.output.file_path}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "geo_enrich",
        "type": "tool",
        "config": {
          "name": "地理位置信息补全",
          "description": "调用外部API补全IP地址的地理位置信息",
          "method": "post",
          "url": "https://httpbin.org/post",
          "headers": "",
          "body": {
            "ips": "{{steps.data_clean.output.cleaned_data}}"
          },
          "variables": {},
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "db_insert",
        "type": "tool",
        "config": {
          "name": "数据入库",
          "description": "将处理后的数据插入云数据库",
          "method": "post",
          "url": "https://httpbin.org/post",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "connection": "{{inputs.db_connection}}",
            "data": "{{steps.geo_enrich.output.enriched_data}}"
          },
          "variables": {},
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "risk_check",
        "type": "ifelse",
        "config": {
          "name": "业务规则判断",
          "description": "根据规则判断是否存在高风险操作",
          "condition": "{{steps.db_insert.output.insert_count}} > 0 and {{steps.alert_rules}} != null",
          "cases": [
            {
              "id": "high_risk",
              "name": "高风险",
              "condition": "{{steps.db_insert.output.risk_score}} > 80"
            },
            {
              "id": "normal",
              "name": "正常",
              "condition": "true"
            }
          ]
        }
      },
      {
        "id": "alert_trigger",
        "type": "llm",
        "config": {
          "name": "告警触发",
          "description": "生成高风险告警邮件内容",
          "prompt": "根据以下数据生成告警邮件：\n风险数据：{{steps.db_insert.output.high_risk_records}}\n规则定义：{{inputs.alert_rules}}\n请生成包含具体操作上下文信息的告警邮件。",
          "variables": {}
        }
      },
      {
        "id": "report_generate",
        "type": "template",
        "config": {
          "name": "报表生成",
          "description": "生成统计报表",
          "template": "{{inputs.report_template}}",
          "variables": {
            "processed_count": "{{steps.db_insert.output.insert_count}}",
            "risk_alerts": "{{steps.alert_trigger.output.alert_content}}",
            "execution_time": "{{global.timestamp}}"
          }
        }
      },
      {
        "id": "aggregator",
        "type": "variable_aggregator",
        "config": {
          "name": "执行结果汇总",
          "description": "汇总所有节点的执行结果",
          "variables": {
            "ftp_status": "{{steps.ftp_download.output.status}}",
            "clean_status": "{{steps.data_clean.output.status}}",
            "geo_status": "{{steps.geo_enrich.output.status}}",
            "db_status": "{{steps.db_insert.output.status}}",
            "risk_status": "{{steps.risk_check.output.branch}}",
            "alert_content": "{{steps.alert_trigger.output.alert_content}}",
            "report_url": "{{steps.report_generate.output.report_url}}",
            "data_count": "{{steps.db_insert.output.insert_count}}"
          }
        }
      },
      {
        "id": "status_report",
        "type": "llm",
        "config": {
          "name": "状态报告生成",
          "description": "生成结构化执行日志和状态报告",
          "prompt": "汇总以下执行信息：\n{{steps.aggregator.output}}\n\n生成包含以下字段的结构化报告：\n1. 各节点状态和时间戳\n2. 详细执行信息\n3. 整体状态评估（成功/失败/部分成功）\n4. 下一次触发时间建议",
          "variables": {}
        }
      },
      {
        "id": "monitor_callback",
        "type": "tool",
        "config": {
          "name": "监控平台回传",
          "description": "将执行结果回传到监控平台",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "summary_report": "{{steps.report_generate.output.report_url}}",
            "execution_log": "{{steps.status_report.output.structured_log}}",
            "alert_status": "{{steps.aggregator.output.risk_status}}",
            "data_processed_count": "{{steps.aggregator.output.data_count}}",
            "overall_status": "{{steps.status_report.output.overall_status}}",
            "next_trigger_time": "{{steps.status_report.output.next_trigger_time}}"
          },
          "variables": {},
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "answer",
        "type": "answer",
        "config": {
          "name": "流程完成",
          "description": "输出最终结果"
        }
