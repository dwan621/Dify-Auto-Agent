  "selected_spec": {
    "workflow_name": "自动化数据处理工作流",
    "description": "一个中等复杂的八节点数据处理工作流，用于每日定时处理FTP服务器上的CSV日志文件。流程包括数据读取、清洗转换、地理位置信息补全、数据入库、业务规则判断、告警触发、报表生成以及执行结果汇总回传。系统支持异常捕获与断点续传。",
    "scene": "generic",
    "inputs": [
      {
        "name": "ftp_config",
        "label": "FTP服务器配置",
        "type": "text",
        "required": true
      },
      {
        "name": "api_key",
        "label": "地理位置API密钥",
        "type": "text",
        "required": true
      },
      {
        "name": "db_connection",
        "label": "云数据库连接字符串",
        "type": "text",
        "required": true
      },
      {
        "name": "alert_email",
        "label": "告警接收邮箱",
        "type": "text",
        "required": true
      },
      {
        "name": "monitor_platform_url",
        "label": "监控平台回传地址",
        "type": "text",
        "required": true
      }
    ],
    "output_contract": {
      "summary_report": "最终生成的统计报表文件或链接",
      "execution_log": "包含各节点状态、时间戳和详细信息的结构化执行日志",
      "final_status": "流程最终执行状态（成功/失败/部分成功）",
      "alert_triggered": "布尔值，指示高风险告警是否被触发"
    },
    "steps": [
      {
        "id": "start",
        "type": "start",
        "config": {
          "variables": [
            "ftp_config",
            "api_key",
            "db_connection",
            "alert_email",
            "monitor_platform_url"
          ]
        }
      },
      {
        "id": "fetch_csv",
        "type": "tool",
        "config": {
          "method": "get",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "action": "fetch_csv",
            "ftp_config": "{{ftp_config}}"
          },
          "variables": [
            "csv_data"
          ],
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "clean_data",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import pandas as pd\nimport json\n\ndef clean_data(csv_data):\n    df = pd.read_csv(pd.compat.StringIO(csv_data))\n    df = df.dropna()\n    df = df.drop_duplicates()\n    df['timestamp'] = pd.to_datetime(df['timestamp'], errors='coerce')\n    df = df.dropna(subset=['timestamp'])\n    return df.to_json(orient='records')\n\ncleaned_data = clean_data({{csv_data}})",
          "example_key": "clean_text",
          "variables": [
            "cleaned_data"
          ],
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "enrich_location",
        "type": "tool",
        "config": {
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": "",
          "body": {
            "data": "{{cleaned_data}}",
            "enrich_fields": [
              "ip_address"
            ]
          },
          "variables": [
            "enriched_data"
          ],
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "store_to_db",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import json\nimport sqlite3\n\ndef store_data(enriched_data, db_connection):\n    data_list = json.loads(enriched_data)\n    conn = sqlite3.connect(':memory:')\n    cursor = conn.cursor()\n    cursor.execute('''CREATE TABLE logs (id INTEGER PRIMARY KEY, timestamp TEXT, ip TEXT, location TEXT)''')\n    for item in data_list:\n        cursor.execute('INSERT INTO logs (timestamp, ip, location) VALUES (?, ?, ?)',\n                       (item.get('timestamp'), item.get('ip_address'), item.get('location', 'Unknown')))\n    conn.commit()\n    row_count = cursor.execute('SELECT COUNT(*) FROM logs').fetchone()[0]\n    conn.close()\n    return row_count\n\nstored_count = store_data({{enriched_data}}, '{{db_connection}}')",
          "variables": [
            "stored_count"
          ],
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "check_anomaly",
        "type": "ifelse",
        "config": {
          "cases": [
            {
              "id": "high_risk",
              "condition": "{{stored_count}} > 1000"
            },
            {
              "id": "normal",
              "condition": "{{stored_count}} <= 1000"
            }
          ]
        }
      },
      {
        "id": "trigger_alert",
        "type": "tool",
        "config": {
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "email": "{{alert_email}}",
            "message": "高风险告警：处理数据量超过1000条",
            "level": "high"
          },
          "variables": [
            "alert_sent"
          ],
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "generate_report",
        "type": "llm",
        "config": {
          "prompt": "基于以下数据处理结果生成一份简要的统计报告：\n- 成功处理的数据记录数：{{stored_count}}条\n- 数据来源：FTP日志文件\n- 处理步骤：清洗、地理位置补全、入库\n- 告警状态：{{alert_triggered}}\n\n报告应包含处理概览、数据质量评估和后续建议。",
          "variables": [
            "summary_report"
          ]
        }
      },
      {
        "id": "aggregate_results",
        "type": "variable_aggregator",
        "config": {
          "variables": [
            "summary_report",
            "execution_log",
            "final_status",
            "alert_triggered"
          ]
        }
      },
      {
        "id": "answer",
        "type": "answer",
        "config": {
          "template": "数据处理工作流执行完成。\n最终状态：{{final_status}}\n处理记录数：{{stored_count}}\n告警触发：{{alert_triggered}}\n报告已生成。"
        }
      },
