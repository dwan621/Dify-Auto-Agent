        }
      },
      {
        "id": "ftp_download",
        "type": "tool",
        "config": {
          "name": "FTP下载CSV文件",
          "description": "从FTP服务器下载当日CSV日志文件",
          "method": "get",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "ftp_config": "{{ftp_config}}",
            "date": "{{current_date}}"
          },
          "variables": {
            "csv_data": "response.body.data"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_cleaning",
        "type": "code",
        "config": {
          "name": "数据清洗与格式化",
          "description": "清洗CSV数据，处理缺失值和格式问题",
          "language": "python",
          "script": "import pandas as pd\nimport json\n\ndef clean_csv_data(csv_content):\n    # 读取CSV数据\n    df = pd.read_csv(pd.compat.StringIO(csv_content))\n    \n    # 处理缺失值\n    df.fillna({'user_id': 'unknown', 'ip_address': '0.0.0.0'}, inplace=True)\n    \n    # 标准化时间格式\n    if 'timestamp' in df.columns:\n        df['timestamp'] = pd.to_datetime(df['timestamp'], errors='coerce')\n    \n    # 移除重复记录\n    df = df.drop_duplicates()\n    \n    # 返回清洗后的数据\n    return df.to_dict(orient='records')\n\ncleaned_data = clean_csv_data(inputs.csv_data)\noutputs.cleaned_data = cleaned_data\noutputs.row_count = len(cleaned_data)",
          "example_key": "clean_text",
          "variables": {
            "cleaned_data": "outputs.cleaned_data",
            "row_count": "outputs.row_count"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "geo_enrichment",
        "type": "tool",
        "config": {
          "name": "地理位置信息补全",
          "description": "调用API补全IP地址的地理位置信息",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": "",
          "body": {
            "ip_addresses": "{{extracted_ips}}",
            "api_key": "{{api_key}}"
          },
          "variables": {
            "geo_data": "response.body.geo_info"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "risk_assessment",
        "type": "ifelse",
        "config": {
          "name": "风险规则判断",
          "description": "根据业务规则判断数据风险等级",
          "condition": "{{row_count}} > 1000 and {{high_risk_count}} > 10",
          "cases": [
            {
              "id": "high_risk",
              "name": "高风险",
              "condition": "true"
            },
            {
              "id": "normal_risk",
              "name": "正常风险",
              "condition": "false"
            }
          ]
        }
      },
      {
        "id": "alert_notification",
        "type": "tool",
        "config": {
          "name": "高风险告警通知",
          "description": "发送高风险告警邮件",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "to": "{{alert_email}}",
            "subject": "高风险数据处理告警",
            "message": "检测到高风险数据记录，请立即检查。高风险数量：{{high_risk_count}}",
            "priority": "high"
          },
          "variables": {
            "alert_sent": "response.body.success"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "report_generation",
        "type": "llm",
        "config": {
          "name": "统计报表生成",
          "description": "生成数据处理的统计报表",
          "prompt": "基于以下数据处理结果生成详细的统计报表：\n- 总处理记录数：{{row_count}}\n- 清洗后有效记录：{{valid_count}}\n- 地理位置补全成功率：{{geo_success_rate}}%\n- 高风险记录数：{{high_risk_count}}\n- 处理时间：{{processing_time}}\n\n请生成包含以下章节的报表：\n1. 执行概览\n2. 数据质量分析\n3. 风险分布\n4. 处理效率\n5. 建议与改进\n\n报表格式要求：使用Markdown格式，包含表格和关键指标突出显示。",
          "variables": {
            "report_content": "response"
          }
        }
      },
      {
        "id": "status_aggregator",
        "type": "variable_aggregator",
        "config": {
          "name": "执行状态汇总",
          "description": "汇总各分支执行状态和结果",
          "variables": {
            "final_status": "{{aggregated_status}}",
            "alert_triggered": "{{alert_triggered_flag}}",
            "summary_report": "{{report_content}}",
            "execution_log": "{{combined_logs}}"
          }
        }
      },
      {
        "id": "answer",
        "type": "answer",
        "config": {
          "name": "流程结果输出",
          "description": "输出最终处理结果"
        }
      },
      {
        "id": "error_handler",
        "type": "code",
        "config": {
          "name": "错误处理与日志记录",
          "description": "捕获和处理流程中的错误，生成错误日志",
          "language": "python",
          "script": "import json\nimport datetime\n\ndef handle_error(error_info, step_name):\n    error_log = {\n        'timestamp': datetime.datetime.now().isoformat(),\n        'step': step_name,\n        'error_type': type(error_info).__name__,\n        'error_message': str(error_info),\n        'status': 'failed'\n    }\n    return error_log\n\n# 记录错误信息\nerror_log = handle_error(inputs.error_info, inputs.step_name)\noutputs.error_log = error_log\noutputs.aggregated_status = 'partial_success'",
          "variables": {
            "error_log": "outputs.error_log",
            "aggregated_status": "outputs.aggregated_status"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "db_writer",
        "type": "code",
        "config": {
          "name": "数据库写入",
          "description": "将处理后的数据写入云数据库",
          "language": "python",
          "script": "import json\nimport psycopg2\nfrom psycopg2 import sql\n\ndef write_to_database(data, connection_string):\n    try:\n        conn = psycopg2.connect(connection_string)\n        cursor = conn.cursor()\n        \n        # 创建临时表\n        create_table = \"\"\"\n        CREATE TABLE IF NOT EXISTS processed_logs (\n            id SERIAL PRIMARY KEY,\n            log_data JSONB,\n            processed_at TIMESTAMP DEFAULT NOW(),\n            status VARCHAR(20)\n        )\n        \"\"\"\n        cursor.execute(create_table)\n        \n        # 插入数据\n        insert_query = \"\"\"\n        INSERT INTO processed_logs (log_data, status)\n        VALUES (%s, %s)\n        \"\"\"\n        \n        for record in data:\n            cursor.execute(insert_query, (json.dumps(record), 'processed'))\n        \n        conn.commit()\n        cursor.close()\n        conn.close()\n        \n        return {'success': True, 'records_inserted': len(data)}\n    except Exception as e:\n        return {'success': False, 'error': str(e)}\n\nresult = write_to_database(inputs.cleaned_data, inputs.db_connection)\noutputs.db_result = result\noutputs.valid_count = len(inputs.cleaned_data) if result['success'] else 0",
          "variables": {
            "db_result": "outputs.db_result",
            "valid_count": "outputs.valid_count"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "monitoring_update",
        "type": "tool",
        "config": {
          "name": "监控平台状态更新",
          "description": "向监控平台回传处理状态",
          "method": "put",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "platform_url": "{{monitoring_platform_url}}",
            "status": "{{final_status}}",
            "timestamp": "{{current_timestamp}}",
            "metrics": {
              "processed_rows": "{{row_count}}",
              "success_rate": "{{success_rate}}"
            }
          },
          "variables": {
            "monitoring_updated": "response.body.updated"
          }
        }
      },
