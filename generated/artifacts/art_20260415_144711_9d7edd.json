      },
      {
        "id": "input_check",
        "type": "code",
        "config": {
          "name": "输入配置校验",
          "description": "检查必要的输入配置是否完整有效",
          "language": "python",
          "script": "def main(ftp_config, api_config, db_config):\n    import json\n    required = ['ftp_config', 'api_config', 'db_config']\n    missing = []\n    for req in required:\n        if not locals().get(req):\n            missing.append(req)\n    if missing:\n        return {'valid': False, 'missing': missing, 'message': f'缺少必要配置: {missing}'}\n    try:\n        json.loads(ftp_config)\n        json.loads(api_config)\n        json.loads(db_config)\n        return {'valid': True, 'message': '配置校验通过'}\n    except Exception as e:\n        return {'valid': False, 'message': f'配置格式错误: {str(e)}'}",
          "variables": {
            "ftp_config": "{{inputs.ftp_config}}",
            "api_config": "{{inputs.api_config}}",
            "db_config": "{{inputs.db_config}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "ftp_fetch",
        "type": "tool",
        "config": {
          "name": "从FTP获取日志文件",
          "description": "使用FTP配置连接服务器并下载CSV日志文件",
          "method": "get",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "action": "ftp_fetch",
            "config": "{{inputs.ftp_config}}"
          },
          "variables": {
            "ftp_config": "{{inputs.ftp_config}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_clean",
        "type": "code",
        "config": {
          "name": "数据清洗与转换",
          "description": "清洗CSV数据，处理缺失值，标准化格式",
          "language": "python",
          "script": "def main(raw_data):\n    import pandas as pd\n    import json\n    from io import StringIO\n    \n    # 假设raw_data是CSV字符串\n    df = pd.read_csv(StringIO(raw_data))\n    \n    # 清洗操作\n    df = df.dropna(subset=['timestamp', 'user_id', 'action'])\n    df['timestamp'] = pd.to_datetime(df['timestamp'], errors='coerce')\n    df = df.dropna(subset=['timestamp'])\n    \n    # 标准化字段\n    if 'ip_address' in df.columns:\n        df['ip_address'] = df['ip_address'].astype(str).str.strip()\n    \n    cleaned_csv = df.to_csv(index=False)\n    stats = {\n        'original_rows': len(raw_data.split('\\n')) - 1,\n        'cleaned_rows': len(df),\n        'dropped_rows': (len(raw_data.split('\\n')) - 1) - len(df),\n        'columns': list(df.columns)\n    }\n    return {'cleaned_data': cleaned_csv, 'stats': stats}",
          "example_key": "clean_text",
          "variables": {
            "raw_data": "{{steps.ftp_fetch.output.body}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "geo_enrich",
        "type": "tool",
        "config": {
          "name": "地理位置信息补全",
          "description": "调用外部API根据IP地址补全地理位置信息",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": "",
          "body": {
            "action": "geo_lookup",
            "ips": "{{ip_list}}",
            "config": "{{inputs.api_config}}"
          },
          "variables": {
            "api_config": "{{inputs.api_config}}",
            "ip_list": "{{steps.data_clean.output.stats.columns}}",
            "api_key": "{{steps.data_clean.output.stats.original_rows}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "db_write",
        "type": "tool",
        "config": {
          "name": "写入云数据库",
          "description": "将处理后的数据写入云数据库",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "action": "db_insert",
            "data": "{{enriched_data}}",
            "config": "{{inputs.db_config}}"
          },
          "variables": {
            "db_config": "{{inputs.db_config}}",
            "enriched_data": "{{steps.geo_enrich.output.body}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "risk_assessment",
        "type": "ifelse",
        "config": {
          "name": "风险评估与规则判断",
          "description": "根据业务规则判断数据中的风险操作",
          "condition": "{{steps.db_write.output.status}} == 'success'",
          "cases": [
            {
              "id": "high_risk",
              "condition": "{{risk_score}} > 80",
              "name": "高风险"
            },
            {
              "id": "medium_risk",
              "condition": "{{risk_score}} > 50",
              "name": "中风险"
            },
            {
              "id": "low_risk",
              "condition": "true",
              "name": "低风险或无风险"
            }
          ],
          "variables": {
            "risk_score": "{{steps.db_write.output.risk_score}}"
          }
        }
      },
      {
        "id": "alert_generation",
        "type": "llm",
        "config": {
          "name": "生成告警通知",
          "description": "根据风险评估结果生成告警消息",
          "prompt": "基于以下风险评估结果生成告警通知：\n风险等级：{{risk_level}}\n风险分数：{{risk_score}}\n触发规则：{{triggered_rules}}\n数据摘要：{{data_summary}}\n\n请生成适合发送给运维团队的告警消息，包含：\n1. 风险等级和分数\n2. 触发的具体规则\n3. 受影响的数据记录\n4. 建议的应对措施\n5. 时间戳和流程ID",
          "variables": {
            "risk_level": "{{steps.risk_assessment.output.selected_case}}",
            "risk_score": "{{steps.db_write.output.risk_score}}",
            "triggered_rules": "{{steps.db_write.output.triggered_rules}}",
            "data_summary": "{{steps.data_clean.output.stats}}"
          }
        }
      },
      {
        "id": "report_creation",
        "type": "template",
        "config": {
          "name": "生成统计报表",
          "description": "根据模板生成数据处理统计报表",
          "template": "数据处理报表\n============\n\n执行时间：{{timestamp}}\n流程ID：{{process_id}}\n\n数据统计：\n- 原始记录数：{{original_rows}}\n- 清洗后记录数：{{cleaned_rows}}\n- 丢弃记录数：{{dropped_rows}}\n\n处理状态：{{status}}\n\n风险告警：\n{{#each alerts}}\n- {{this}}\n{{/each}}\n\n地理位置补全：{{geo_enriched_count}} 条记录\n\n数据库写入：{{db_success_count}} 成功 / {{db_failed_count}} 失败",
          "variables": {
            "timestamp": "{{system.timestamp}}",
            "process_id": "{{system.process_id}}",
            "original_rows": "{{steps.data_clean.output.stats.original_rows}}",
            "cleaned_rows": "{{steps.data_clean.output.stats.cleaned_rows}}",
            "dropped_rows": "{{steps.data_clean.output.stats.dropped_rows}}",
            "status": "{{steps.db_write.output.status}}",
