        "type": "code",
        "config": {
          "language": "python",
          "script": "def clean_text(text):\n    # 去除多余空白字符，保留基本格式\n    import re\n    text = text.strip()\n    text = re.sub(r'\\s+', ' ', text)\n    return text",
