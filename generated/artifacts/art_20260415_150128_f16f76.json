        "type": "llm",
        "config": {
          "prompt": "对以下中文翻译进行润色，使其更加自然流畅、符合中文表达习惯。\n翻译草稿：{{translate_core.draft_translation}}\n原文：{{inputs.english_text}}\n\n润色要求：1. 优化句式结构 2. 调整用词准确性 3. 确保语言自然 4. 检查文化适应性",
          "model": "deepseek-chat",
          "temperature": 0.2,
          "variables": {
            "polished_translation": "润色后的翻译"
          }
        }
