    "steps": [
      {
        "id": "start",
        "type": "start",
        "config": {
          "name": "开始节点",
          "description": "流程启动节点"
        }
      },
      {
        "id": "ftp_file_reader",
        "type": "tool",
        "config": {
          "name": "FTP文件读取",
          "description": "从FTP服务器读取CSV日志文件",
          "method": "get",
          "url": "https://httpbin.org/get",
          "headers": {},
          "body": {},
          "variables": {
            "ftp_config": "{{inputs.ftp_config}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_cleaner",
        "type": "code",
        "config": {
          "name": "数据清洗转换",
          "description": "去除空值并过滤预定义的异常模式",
          "language": "python",
          "script": "import pandas as pd\nimport json\n\ndef clean_data(raw_data):\n    # 解析CSV数据\n    df = pd.read_csv(pd.compat.StringIO(raw_data))\n    \n    # 去除空值\n    df = df.dropna()\n    \n    # 过滤异常模式（示例：过滤特定IP范围）\n    df = df[~df['ip_address'].str.startswith('192.168.')]\n    \n    return df.to_dict(orient='records')\n\n# 执行清洗\ncleaned_data = clean_data(input_data)",
          "example_key": "clean_text",
          "variables": {
            "input_data": "{{steps.ftp_file_reader.output}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "geo_enrichment",
        "type": "tool",
        "config": {
          "name": "地理位置信息补全",
          "description": "调用外部API补全地理位置信息",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": "",
          "body": {
            "data": "{{steps.data_cleaner.output}}"
          },
          "variables": {
            "api_key": "{{inputs.api_key}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "database_writer",
        "type": "code",
        "config": {
          "name": "数据入库",
          "description": "将处理后的数据写入云数据库",
          "language": "python",
          "script": "import psycopg2\nimport json\n\ndef write_to_db(data, connection_string):\n    conn = psycopg2.connect(connection_string)\n    cursor = conn.cursor()\n    \n    records_processed = 0\n    for record in data:\n        try:\n            cursor.execute(\n                \"INSERT INTO logs (timestamp, ip, location, event) VALUES (%s, %s, %s, %s)\",\n                (record['timestamp'], record['ip'], record['location'], record['event'])\n            )\n            records_processed += 1\n        except Exception as e:\n            print(f\"Error inserting record: {e}\")\n    \n    conn.commit()\n    cursor.close()\n    conn.close()\n    \n    return {\"records_processed\": records_processed}\n\n# 执行写入\nresult = write_to_db(input_data, db_connection)",
          "example_key": "parse_json",
          "variables": {
            "input_data": "{{steps.geo_enrichment.output}}",
            "db_connection": "{{inputs.db_connection}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "risk_analysis",
        "type": "ifelse",
        "config": {
          "name": "业务规则判断",
          "description": "判断是否存在高风险操作",
          "condition": "{{steps.database_writer.output.records_processed}} > 0 and {{steps.database_writer.output.high_risk_count}} > 10",
          "cases": [
            {
              "id": "high_risk",
              "name": "高风险",
              "condition": "true"
            },
            {
              "id": "normal",
              "name": "正常",
              "condition": "false"
            }
          ]
        }
      },
      {
        "id": "alert_sender",
        "type": "tool",
        "config": {
          "name": "告警触发",
          "description": "发送高风险告警邮件",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "recipients": "{{inputs.alert_recipients}}",
            "subject": "高风险操作告警",
            "message": "检测到超过10条高风险操作记录"
          },
          "variables": {
            "alert_recipients": "{{inputs.alert_recipients}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "report_generator",
        "type": "llm",
        "config": {
          "name": "报表生成",
          "description": "生成统计报表",
          "prompt": "基于以下数据处理结果生成统计报表：\n- 处理记录数：{{steps.database_writer.output.records_processed}}\n- 高风险操作数：{{steps.database_writer.output.high_risk_count or 0}}\n- 地理位置补全成功率：{{steps.geo_enrichment.output.success_rate}}\n\n请生成包含以下内容的报表：\n1. 数据概览\n2. 处理统计\n3. 质量指标\n4. 风险分析\n5. 建议措施",
          "model": "deepseek-chat",
          "temperature": 0.3
        }
      },
      {
        "id": "status_aggregator",
        "type": "variable_aggregator",
        "config": {
          "name": "执行状态汇总",
          "description": "汇总所有节点的执行状态和日志",
          "variables": {
            "ftp_status": "{{steps.ftp_file_reader.status}}",
            "clean_status": "{{steps.data_cleaner.status}}",
            "geo_status": "{{steps.geo_enrichment.status}}",
            "db_status": "{{steps.database_writer.status}}",
            "records_processed": "{{steps.database_writer.output.records_processed}}",
            "alert_triggered": "{{steps.risk_analysis.selected_case}} == 'high_risk'",
            "report_content": "{{steps.report_generator.output}}"
          }
        }
      },
      {
        "id": "monitoring_reporter",
        "type": "tool",
        "config": {
          "name": "监控平台回传",
          "description": "将执行结果回传到监控平台",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "summary_report": "{{steps.report_generator.output}}",
            "execution_log": "{{steps.status_aggregator.output}}",
            "final_status": "{{steps.status_aggregator.output.overall_status}}",
            "alert_triggered": "{{steps.status_aggregator.output.alert_triggered}}",
            "records_processed": "{{steps.status_aggregator.output.records_processed}}"
          },
          "variables": {
            "monitoring_url": "{{inputs.monitoring_platform_url}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
