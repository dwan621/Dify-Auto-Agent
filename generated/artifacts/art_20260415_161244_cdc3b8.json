      {
        "id": "ftp_download",
        "type": "tool",
        "config": {
          "name": "FTP文件下载",
          "description": "从FTP服务器下载CSV日志文件",
          "method": "get",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "ftp_config": "{{inputs.ftp_config}}",
            "operation": "download_csv"
          },
          "variables": {
            "downloaded_file": "response.body.file_content",
            "file_metadata": "response.body.metadata"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_cleaning",
        "type": "code",
        "config": {
          "name": "数据清洗转换",
          "description": "清洗CSV数据，去除空值与异常",
          "language": "python",
          "script": "import pandas as pd\nimport json\n\ndef process(data):\n    raw_data = json.loads(data['downloaded_file'])\n    df = pd.DataFrame(raw_data)\n    \n    # 去除空值\n    df_cleaned = df.dropna()\n    \n    # 去除异常值（示例：数值型字段超出合理范围）\n    if 'value' in df_cleaned.columns:\n        df_cleaned = df_cleaned[(df_cleaned['value'] >= 0) & (df_cleaned['value'] <= 10000)]\n    \n    # 格式转换\n    df_cleaned['timestamp'] = pd.to_datetime(df_cleaned['timestamp'])\n    \n    return {\n        'cleaned_data': df_cleaned.to_dict('records'),\n        'original_count': len(df),\n        'cleaned_count': len(df_cleaned),\n        'removed_count': len(df) - len(df_cleaned)\n    }",
          "example_key": "clean_text",
          "variables": {
            "cleaned_data": "output.cleaned_data",
            "cleaning_stats": "output"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "geo_enrichment",
        "type": "tool",
        "config": {
          "name": "地理位置信息补全",
          "description": "调用外部API补全IP地址的地理位置信息",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": "",
          "body": {
            "ip_list": "{{steps.data_cleaning.config.variables.cleaned_data}}",
            "fields": [
              "country",
              "city",
              "latitude",
              "longitude"
            ]
          },
          "variables": {
            "enriched_data": "response.body.enriched_records",
            "enrichment_stats": "response.body.stats"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_import",
        "type": "code",
        "config": {
          "name": "数据入库",
          "description": "将处理后的数据导入云数据库",
          "language": "python",
          "script": "import json\nimport psycopg2\nfrom psycopg2 import sql\n\ndef process(data):\n    enriched_data = data['enriched_data']\n    db_config = json.loads(data['inputs']['db_connection'])\n    \n    try:\n        conn = psycopg2.connect(\n            host=db_config['host'],\n            database=db_config['database'],\n            user=db_config['user'],\n            password=db_config['password']\n        )\n        cursor = conn.cursor()\n        \n        # 创建临时表或插入数据\n        insert_count = 0\n        for record in enriched_data:\n            # 这里简化处理，实际应根据表结构编写SQL\n            cursor.execute(\n                \"INSERT INTO log_data (timestamp, ip, country, city) VALUES (%s, %s, %s, %s)\",\n                (record['timestamp'], record['ip'], record.get('country'), record.get('city'))\n            )\n            insert_count += 1\n        \n        conn.commit()\n        cursor.close()\n        conn.close()\n        \n        return {\n            'imported_count': insert_count,\n            'status': 'success'\n        }\n    except Exception as e:\n        return {\n            'imported_count': 0,\n            'status': 'failed',\n            'error': str(e)\n        }",
          "example_key": "parse_json",
          "variables": {
            "import_result": "output"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "risk_detection",
        "type": "ifelse",
        "config": {
          "name": "高风险操作检测",
          "description": "基于规则引擎检测高风险操作",
          "condition": "{{steps.data_import.config.variables.import_result.status}} == 'success' and {{inputs.alert_rules}}",
          "cases": [
            {
              "id": "high_risk",
              "condition": "risk_score > 80",
              "name": "高风险"
            },
            {
              "id": "medium_risk",
              "condition": "risk_score > 50",
              "name": "中风险"
            },
            {
              "id": "low_risk",
              "condition": "risk_score <= 50",
              "name": "低风险"
            }
          ]
        }
      },
      {
        "id": "alert_trigger",
        "type": "tool",
        "config": {
          "name": "告警触发",
          "description": "触发高风险告警通知",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "risk_level": "{{steps.risk_detection.config.selected_case}}",
            "data_summary": "{{steps.data_cleaning.config.variables.cleaning_stats}}",
            "timestamp": "{{context.timestamp}}"
          },
          "variables": {
            "alert_response": "response.body"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "report_generation",
        "type": "llm",
        "config": {
          "name": "报表生成",
          "description": "生成数据处理的统计报表",
          "prompt": "基于以下数据处理结果生成统计报表：\n\n数据清洗统计：{{steps.data_cleaning.config.variables.cleaning_stats}}\n地理位置补全统计：{{steps.geo_enrichment.config.variables.enrichment_stats}}\n数据入库结果：{{steps.data_import.config.variables.import_result}}\n风险检测结果：{{steps.risk_detection.config.selected_case}}\n告警状态：{{steps.alert_trigger.config.variables.alert_response}}\n\n请生成包含以下内容的报表：\n1. 数据处理概览\n2. 各阶段数据量统计\n3. 数据质量分析\n4. 风险识别情况\n5. 建议与改进措施\n\n使用专业、简洁的商务报告格式。",
          "variables": {
            "report_content": "response"
          }
        }
      },
