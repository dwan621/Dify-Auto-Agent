        "name": "report_template",
        "label": "统计报表模板",
        "type": "file",
        "required": false
      }
    ],
    "output_contract": {
      "summary_report": "每日数据处理与分析的汇总报告（JSON格式）",
      "execution_log": "包含各节点状态、时间戳及详细信息的完整执行日志",
      "alert_status": "本次流程运行中触发的告警记录（如有）",
      "data_status": "数据清洗、转换、入库的记录数与状态",
      "process_status": "整体流程的成功/失败状态及错误信息（如有）"
    },
    "steps": [
      {
        "id": "start",
        "type": "start",
        "config": {
          "name": "开始",
          "description": "流程开始节点"
        }
      },
      {
        "id": "input_check",
        "type": "code",
        "config": {
          "name": "输入参数校验",
          "description": "校验FTP配置、API密钥等必要输入参数",
          "language": "python",
          "script": "def main(ftp_config, api_key, db_config, alert_rules, report_template):\n    # 校验必要参数\n    if not ftp_config or not api_key or not db_config:\n        raise ValueError('缺少必要参数: ftp_config, api_key, db_config')\n    \n    # 解析配置\n    try:\n        ftp_config_dict = eval(ftp_config)\n        db_config_dict = eval(db_config)\n    except:\n        raise ValueError('配置参数格式错误')\n    \n    return {\n        'ftp_config': ftp_config_dict,\n        'api_key': api_key,\n        'db_config': db_config_dict,\n        'alert_rules': alert_rules,\n        'report_template': report_template,\n        'status': 'valid'\n    }",
          "variables": {
            "ftp_config": "{{inputs.ftp_config}}",
            "api_key": "{{inputs.api_key}}",
            "db_config": "{{inputs.db_config}}",
            "alert_rules": "{{inputs.alert_rules}}",
            "report_template": "{{inputs.report_template}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "ftp_download",
        "type": "tool",
        "config": {
          "name": "FTP文件下载",
          "description": "从FTP服务器下载CSV日志文件",
          "method": "get",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "action": "ftp_download",
            "config": "{{steps.input_check.output.ftp_config}}",
            "file_pattern": "*.csv",
            "date": "{{system.date}}"
          },
          "variables": {
            "ftp_config": "{{steps.input_check.output.ftp_config}}"
          },
          "timeout": 300,
          "retry_count": 3,
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_clean",
        "type": "code",
        "config": {
          "name": "数据清洗转换",
          "description": "清洗CSV数据，处理缺失值、格式转换",
          "language": "python",
          "script": "import pandas as pd\nimport json\n\ndef main(raw_data):\n    # 模拟数据处理\n    df = pd.DataFrame(raw_data.get('data', []))\n    \n    # 数据清洗\n    df = df.dropna()\n    df = df.drop_duplicates()\n    \n    # 格式转换\n    if 'timestamp' in df.columns:\n        df['timestamp'] = pd.to_datetime(df['timestamp'])\n    \n    # 统计信息\n    stats = {\n        'total_records': len(df),\n        'cleaned_records': len(df),\n        'columns': list(df.columns),\n        'sample_data': df.head(3).to_dict('records')\n    }\n    \n    return {\n        'cleaned_data': df.to_dict('records'),\n        'stats': stats,\n        'status': 'success'\n    }",
          "example_key": "clean_text",
          "variables": {
            "raw_data": "{{steps.ftp_download.output}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "geo_enrich",
        "type": "tool",
        "config": {
          "name": "地理位置信息补全",
          "description": "调用地理位置API补全IP地址信息",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": "",
          "body": {
            "action": "geo_lookup",
            "data": "{{steps.data_clean.output.cleaned_data}}",
            "fields": [
              "ip_address"
            ]
          },
          "variables": {
            "api_key": "{{steps.input_check.output.api_key}}",
            "cleaned_data": "{{steps.data_clean.output.cleaned_data}}"
          },
          "timeout": 180,
          "retry_count": 3,
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "db_import",
        "type": "tool",
        "config": {
          "name": "数据入库",
          "description": "将处理后的数据导入云数据库",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "action": "db_import",
            "config": "{{steps.input_check.output.db_config}}",
            "data": "{{steps.geo_enrich.output}}",
            "table": "daily_logs"
          },
          "variables": {
            "db_config": "{{steps.input_check.output.db_config}}",
            "enriched_data": "{{steps.geo_enrich.output}}"
          },
          "timeout": 240,
          "retry_count": 3,
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "business_rules",
        "type": "ifelse",
        "config": {
          "name": "业务规则判断",
          "description": "根据业务规则判断数据风险等级",
          "cases": [
            {
              "id": "high_risk",
              "condition": "{{steps.db_import.output.risk_score}} > 80",
              "name": "高风险"
            },
            {
              "id": "medium_risk",
              "condition": "{{steps.db_import.output.risk_score}} > 50",
              "name": "中风险"
            },
            {
              "id": "low_risk",
              "condition": "true",
              "name": "低风险"
            }
          ]
        }
      },
      {
        "id": "alert_trigger",
        "type": "llm",
        "config": {
          "name": "告警触发",
          "description": "根据风险等级生成告警信息",
          "prompt": "根据以下业务规则和数据风险分析结果，生成相应的告警信息：\n\n业务规则：{{steps.input_check.output.alert_rules}}\n\n风险分析结果：{{steps.db_import.output.risk_analysis}}\n\n风险等级：{{steps.business_rules.output.selected_case}}\n\n请生成结构化的告警信息，包括：告警级别、告警内容、建议措施、相关数据指标。",
          "variables": {
            "alert_rules": "{{steps.input_check.output.alert_rules}}",
            "risk_analysis": "{{steps.db_import.output.risk_analysis}}",
            "selected_case": "{{steps.business_rules.output.selected_case}}"
          },
          "model": "deepseek-chat"
        }
      },
      {
        "id": "report_generation",
        "type": "template",
        "config": {
          "name": "报表生成",
          "description": "生成每日数据处理统计报表",
          "template": "{\n  \"report_date\": \"{{system.date}}\",\n  \"data_processing\": {\n    \"total_records\": {{steps.data_clean.output.stats.total_records}},\n    \"cleaned_records\": {{steps.data_clean.output.stats.cleaned_records}},\n    \"enriched_records\": {{steps.geo_enrich.output.enriched_count}},\n    \"imported_records\": {{steps.db_import.output.imported_count}}\n  },\n  \"risk_analysis\": {\n    \"risk_level\": \"{{steps.business_rules.output.selected_case}}\",\n    \"risk_score\": {{steps.db_import.output.risk_score}},\n    \"high_risk_items\": {{steps.db_import.output.high_risk_items}}\n  },\n  \"alerts\": {{steps.alert_trigger.output}},\n  \"execution_summary\": {\n    \"start_time\": \"{{system.start_time}}\",\n    \"end_time\": \"{{system.current_time}}\",\n    \"status\": \"{{steps.db_import.output.status}}\"\n  }\n}",
          "variables": {
            "date": "{{system.date}}",
            "data_stats": "{{steps.data_clean.output.stats}}",
            "geo_stats": "{{steps.geo_enrich.output}}",
            "db_stats": "{{steps.db_import.output}}",
            "risk_case": "{{steps.business_rules.output.selected_case}}",
            "alerts": "{{steps.alert_trigger.output}}"
          }
        }
      },
      {
        "id": "aggregator_success",
        "type": "variable_aggregator",
        "config": {
          "name": "成功分支聚合",
          "description": "聚合成功分支的执行结果",
          "variables": {
            "data_status": {
              "cleaned": "{{steps.data_clean.output.stats}}",
              "enriched": "{{steps.geo_enrich.output}}",
              "imported": "{{steps.db_import.output}}"
            },
            "alert_status": "{{steps.alert_trigger.output}}",
            "summary_report": "{{steps.report_generation.output}}",
            "process_status": "success"
          }
        }
      },
      {
