      {
        "id": "input_validation",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import json\ninputs = workflow_inputs\nrequired = ['ftp_config', 'db_connection', 'api_key', 'monitoring_platform_url']\nmissing = [r for r in required if not inputs.get(r)]\nif missing:\n    raise ValueError(f'缺少必要输入: {missing}')\nprint('输入验证通过')\nreturn {'validated': True}",
          "variables": {
            "workflow_inputs": "{{inputs}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "ftp_file_list",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import json\nftp_config_str = workflow_inputs['ftp_config']\nftp_config = json.loads(ftp_config_str)\nhost = ftp_config.get('host')\nport = ftp_config.get('port', 21)\nusername = ftp_config.get('username')\npassword = ftp_config.get('password')\npath = ftp_config.get('path', '/')\nprint(f'模拟连接FTP: {host}:{port}')\nprint(f'路径: {path}')\nfiles = ['log_20240501.csv', 'log_20240502.csv', 'log_20240503.csv']\nreturn {'files': files, 'count': len(files)}",
          "variables": {
            "workflow_inputs": "{{inputs}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "download_and_parse",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import pandas as pd\nimport io\nfiles = ftp_files['files']\ndataframes = []\nfor f in files:\n    print(f'处理文件: {f}')\n    df = pd.DataFrame({\n        'timestamp': ['2024-05-01 10:00:00', '2024-05-01 11:00:00'],\n        'user_id': [1001, 1002],\n        'ip': ['192.168.1.1', '192.168.1.2'],\n        'action': ['login', 'logout'],\n        'status': [200, 404]\n    })\n    dataframes.append(df)\ncombined = pd.concat(dataframes, ignore_index=True)\nprint(f'合并后数据行数: {len(combined)}')\nreturn {'raw_data': combined.to_dict(orient='records'), 'file_count': len(files)}",
          "variables": {
            "ftp_files": "{{ftp_file_list.output}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_cleaning",
        "type": "code",
        "config": {
          "language": "python",
          "example_key": "clean_text",
          "script": "import pandas as pd\nraw = pd.DataFrame(raw_data)\nprint(f'清洗前数据行数: {len(raw)}')\nraw = raw.dropna()\nraw = raw[raw['status'].astype(str).str.isdigit()]\nraw['status'] = raw['status'].astype(int)\nprint(f'清洗后数据行数: {len(raw)}')\nreturn {'cleaned_data': raw.to_dict(orient='records'), 'cleaned_count': len(raw)}",
          "variables": {
            "raw_data": "{{download_and_parse.output.raw_data}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "geo_enrichment",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import pandas as pd\nimport requests\ncleaned = pd.DataFrame(cleaned_data)\napikey = workflow_inputs['api_key']\nprint(f'使用API密钥: {apikey[:5]}...')\nenriched = []\nfor idx, row in cleaned.iterrows():\n    ip = row['ip']\n    geo = {'country': 'China', 'city': 'Beijing', 'isp': 'China Telecom'}\n    enriched.append({**row.to_dict(), **geo})\nprint(f'地理位置补全完成，共处理 {len(enriched)} 条记录')\nreturn {'enriched_data': enriched}",
          "variables": {
            "cleaned_data": "{{data_cleaning.output.cleaned_data}}",
            "workflow_inputs": "{{inputs}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "db_insert",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import json\nenriched = enriched_data\ndb_conn_str = workflow_inputs['db_connection']\nprint(f'模拟连接数据库: {db_conn_str[:20]}...')\nprint(f'插入 {len(enriched)} 条记录')\ninserted = len(enriched)\nreturn {'inserted_rows': inserted}",
          "variables": {
            "enriched_data": "{{geo_enrichment.output.enriched_data}}",
            "workflow_inputs": "{{inputs}}"
          }
        }
      },
      {
        "id": "risk_analysis",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import pandas as pd\nenriched = pd.DataFrame(enriched_data)\nanomalies = 0\nalerts = 0\nfor idx, row in enriched.iterrows():\n    if row['status'] >= 400:\n        anomalies += 1\n    if row['status'] == 404 and row['action'] == 'login':\n        alerts += 1\nprint(f'异常数: {anomalies}, 告警数: {alerts}')\nreturn {'anomalies': anomalies, 'alerts': alerts}",
          "variables": {
            "enriched_data": "{{geo_enrichment.output.enriched_data}}"
          }
        }
      },
      {
        "id": "report_generation",
        "type": "llm",
        "config": {
          "prompt": "根据以下数据生成日报摘要：\n- 处理文件数: {{download_and_parse.output.file_count}}\n- 清洗后数据行数: {{data_cleaning.output.cleaned_count}}\n- 入库行数: {{db_insert.output.inserted_rows}}\n- 异常数: {{risk_analysis.output.anomalies}}\n- 告警数: {{risk_analysis.output.alerts}}\n\n请生成结构化的日报，包含概述、关键指标、风险分析和建议。",
          "variables": {
            "download_and_parse.output.file_count": "{{download_and_parse.output.file_count}}",
            "data_cleaning.output.cleaned_count": "{{data_cleaning.output.cleaned_count}}",
            "db_insert.output.inserted_rows": "{{db_insert.output.inserted_rows}}",
            "risk_analysis.output.anomalies": "{{risk_analysis.output.anomalies}}",
            "risk_analysis.output.alerts": "{{risk_analysis.output.alerts}}"
          },
          "model": "deepseek-chat"
        }
      },
