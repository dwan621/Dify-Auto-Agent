        "id": "report_formatting",
        "type": "code",
        "config": {
          "language": "python",
          "example_key": "format_markdown",
          "script": "report_text = report_generation\nformatted = f'# 数据处理日报\\n\\n{report_text}\\n\\n---\\n*生成时间: 2024-05-01*'\nreturn {'formatted_report': formatted}",
          "variables": {
            "report_generation": "{{report_generation.output}}"
