        "config": {
          "name": "输入参数检查",
          "language": "python",
          "script": "import json\ninputs = context.get('inputs', {})\nrequired = ['ftp_config', 'db_connection', 'api_key', 'monitoring_platform_url']\nmissing = [field for field in required if not inputs.get(field)]\nif missing:\n    raise ValueError(f'缺少必要参数: {missing}')\nreturn {'status': 'inputs_valid'",
