      {
        "id": "ftp_connect",
        "type": "code",
        "config": {
          "name": "连接FTP服务器",
          "language": "python",
          "script": "import json\nimport ftplib\nfrom io import BytesIO\n\nftp_config = json.loads(context.get('ftp_config'))\nhost = ftp_config.get('host')\nport = ftp_config.get('port', 21)\nusername = ftp_config.get('username')\npassword = ftp_config.get('password')\npath = ftp_config.get('path', '/')\n\nftp = ftplib.FTP()\nftp.connect(host, port)\nftp.login(username, password)\nftp.cwd(path)\n\nfiles = []\nftp.retrlines('LIST', files.append)\ncsv_files = [f.split()[-1] for f in files if f.lower().endswith('.csv')]\n\nfile_contents = {}\nfor filename in csv_files[:5]:  # 限制处理前5个文件\n    bio = BytesIO()\n    ftp.retrbinary(f'RETR {filename}', bio.write)\n    file_contents[filename] = bio.getvalue().decode('utf-8')\n\nftp.quit()\nreturn {\n    'connected': True",
          "files_found": "csv_files",
          "file_contents": "file_contents",
          "processed_count": "len(file_contents)\n}",
          "variables": {
            "ftp_config": "{{inputs.ftp_config}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_clean",
        "type": "code",
        "config": {
          "name": "数据清洗",
          "language": "python",
          "script": "import pandas as pd\nimport json\nfrom io import StringIO\n\nfile_contents = context.get('file_contents', {})\ncleaned_data = {}\n\nfor filename, content in file_contents.items():\n    try:\n        df = pd.read_csv(StringIO(content))\n        # 去除空行\n        df = df.dropna(how='all')\n        # 去除重复行\n        df = df.drop_duplicates()\n        # 标准化列名\n        df.columns = df.columns.str.strip().str.lower().str.replace(' ', '_')\n        # 确保必要列存在\n        required_cols = ['timestamp', 'ip_address', 'user_id', 'action']\n        for col in required_cols:\n            if col not in df.columns:\n                df[col] = None\n        \n        cleaned_data[filename] = df.to_dict('records')\n    except Exception as e:\n        print(f'Error processing {filename}: {e}')\n        continue\n\nreturn {\n    'cleaned_files': list(cleaned_data.keys())",
          "cleaned_data": "cleaned_data",
          "total_records": "sum(len(data) for data in cleaned_data.values())\n}",
          "example_key": "clean_text",
          "variables": {
            "file_contents": "{{ftp_connect.output.file_contents}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "ip_geo_enrich",
        "type": "code",
        "config": {
          "name": "IP地理位置补全",
          "language": "python",
          "script": "import json\nimport requests\n\ncleaned_data = context.get('cleaned_data', {})\napi_key = context.get('api_key')\nenriched_data = {}\nip_cache = {}\n\nfor filename, records in cleaned_data.items():\n    enriched_records = []\n    for record in records:\n        ip = record.get('ip_address')\n        enriched_record = record.copy()\n        \n        if ip and ip not in ip_cache:\n            try:\n                response = requests.get(f'http://ip-api.com/json/{ip}', timeout=5)\n                if response.status_code == 200:\n                    geo_data = response.json()\n                    ip_cache[ip] = {\n                        'country': geo_data.get('country')",
          "region": "Unknown",
