    "output_contract": {
      "summary_report": "最终生成的统计报表文件或链接",
      "execution_log": "包含各节点状态、时间戳和详细信息的完整执行日志",
      "alert_status": "本次流程运行中是否触发了告警及告警详情",
      "data_processing_summary": "数据处理的摘要信息（如处理记录数、成功/失败数）",
      "final_status": "流程最终状态（成功、失败、部分成功）及错误信息（如有）"
    },
    "steps": [
      {
        "id": "start",
        "type": "start",
        "config": {
          "name": "开始",
          "description": "流程开始节点"
        }
      },
      {
        "id": "ftp_download",
        "type": "tool",
        "config": {
          "name": "FTP日志下载",
          "description": "从FTP服务器下载CSV日志文件",
          "method": "get",
          "url": "https://httpbin.org/get",
          "headers": {},
          "body": {},
          "variables": {
            "ftp_config": "{{inputs.ftp_config}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_clean",
        "type": "code",
        "config": {
          "name": "数据清洗转换",
          "description": "清洗CSV数据，处理缺失值和格式转换",
          "language": "python",
          "script": "import pandas as pd\nimport json\n\ndef clean_data(raw_data):\n    # 解析CSV数据\n    df = pd.read_csv(pd.compat.StringIO(raw_data))\n    \n    # 清洗操作\n    df = df.dropna()\n    df['timestamp'] = pd.to_datetime(df['timestamp'])\n    \n    # 返回清洗后的数据\n    return df.to_json(orient='records')\n\n# 执行清洗\ncleaned_data = clean_data({{steps.ftp_download.output}})\noutput = {'cleaned_data': cleaned_data, 'record_count': len(json.loads(cleaned_data))}",
          "example_key": "clean_text",
          "variables": {
            "raw_data": "{{steps.ftp_download.output}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "geo_enrich",
        "type": "tool",
        "config": {
          "name": "地理位置信息补全",
          "description": "调用外部API补全IP地址的地理位置信息",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": "",
          "body": {
            "data": "{{steps.data_clean.output.cleaned_data}}"
          },
          "variables": {
            "api_credentials": "{{inputs.api_credentials}}",
            "cleaned_data": "{{steps.data_clean.output.cleaned_data}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "db_insert",
        "type": "tool",
        "config": {
          "name": "数据入库",
          "description": "将处理后的数据写入云数据库",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "connection": "{{inputs.db_connection}}",
            "data": "{{steps.geo_enrich.output}}"
          },
          "variables": {
            "db_connection": "{{inputs.db_connection}}",
            "enriched_data": "{{steps.geo_enrich.output}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "risk_check",
        "type": "ifelse",
        "config": {
          "name": "业务规则判断",
          "description": "根据规则判断是否存在高风险操作",
          "condition": "{{steps.db_insert.output.success}} and {{steps.data_clean.output.record_count}} > 0",
          "cases": [
            {
              "id": "high_risk",
              "condition": "{{steps.llm_analyze.output.risk_level}} == 'high'",
              "name": "高风险"
            },
            {
              "id": "normal",
              "condition": "{{steps.llm_analyze.output.risk_level}} == 'normal'",
              "name": "正常"
            }
          ]
        }
      },
      {
        "id": "llm_analyze",
        "type": "llm",
        "config": {
          "name": "风险分析",
          "description": "使用LLM分析数据中的风险模式",
          "model": "deepseek-chat",
          "prompt": "分析以下日志数据中的风险模式，识别高风险操作。数据：{{steps.db_insert.output}}。规则：{{inputs.alert_rules}}。请返回JSON格式：{\"risk_level\": \"high\"或\"normal\", \"risk_details\": \"风险描述\"}",
          "variables": {
            "processed_data": "{{steps.db_insert.output}}",
            "alert_rules": "{{inputs.alert_rules}}"
          }
        }
      },
      {
        "id": "trigger_alert",
        "type": "tool",
        "config": {
          "name": "告警触发",
          "description": "向监控平台发送告警信息",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "alert_type": "data_risk",
            "details": "{{steps.llm_analyze.output.risk_details}}",
            "timestamp": "{{system.timestamp}}"
          },
          "variables": {
            "monitoring_url": "{{inputs.monitoring_platform_url}}",
            "risk_details": "{{steps.llm_analyze.output.risk_details}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "generate_report",
        "type": "template",
        "config": {
          "name": "报表生成",
          "description": "生成统计报表",
          "template": "数据处理报告\n============\n\n执行时间：{{system.timestamp}}\n处理记录数：{{steps.data_clean.output.record_count}}\n风险等级：{{steps.llm_analyze.output.risk_level}}\n风险详情：{{steps.llm_analyze.output.risk_details}}\n\n处理摘要：\n- 数据清洗：成功\n- 地理位置补全：{{steps.geo_enrich.output.status}}\n- 数据入库：{{steps.db_insert.output.status}}\n- 告警触发：{{steps.trigger_alert.output.status if steps.risk_check.branch == 'high_risk' else '未触发'}}",
          "variables": {
            "record_count": "{{steps.data_clean.output.record_count}}",
            "risk_level": "{{steps.llm_analyze.output.risk_level}}",
            "risk_details": "{{steps.llm_analyze.output.risk_details}}"
          }
        }
      },
      {
        "id": "aggregate_results",
        "type": "variable_aggregator",
        "config": {
          "name": "结果汇总",
          "description": "汇总各分支执行结果",
          "variables": {
            "data_summary": {
              "record_count": "{{steps.data_clean.output.record_count}}",
              "enrichment_status": "{{steps.geo_enrich.output.status}}",
              "db_status": "{{steps.db_insert.output.status}}"
            },
            "risk_analysis": {
              "risk_level": "{{steps.llm_analyze.output.risk_level}}",
              "risk_details": "{{steps.llm_analyze.output.risk_details}}",
              "alert_triggered": "{{steps.risk_check.branch == 'high_risk'}}"
            },
            "report_content": "{{steps.generate_report.output}}"
          }
        }
      },
      {
        "id": "answer",
        "type": "answer",
        "config": {
          "name": "最终输出",
          "description": "输出处理结果"
        }
      },
      {
