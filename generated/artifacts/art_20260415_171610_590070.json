        "label": "告警接收人",
        "type": "text",
        "required": false
      }
    ],
    "output_contract": {
      "run_id": "string",
      "processed_files": "array",
      "inserted_rows": "number",
      "anomalies": "array",
      "alerts": "array",
      "report": "string",
      "status": "string"
    },
    "steps": [
      {
        "id": "start",
        "type": "start",
        "config": {}
      },
      {
        "id": "input_check",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import json\ninputs = json.loads(inputs)\nrequired = ['ftp_config', 'db_connection', 'api_key', 'monitoring_platform_url']\nmissing = [field for field in required if field not in inputs or not inputs[field]]\nif missing:\n    raise ValueError(f'缺少必要输入字段: {missing}')\noutput = {'status': 'inputs_valid', 'timestamp': '2024-01-01T00:00:00Z'}\nreturn output",
          "example_key": "parse_json",
          "variables": {
            "inputs": "{{inputs}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "plan_processing",
        "type": "llm",
        "config": {
          "model": "deepseek-chat",
          "prompt": "基于FTP配置和当前时间，规划今天的日志处理任务。FTP配置：{{ftp_config}}。当前时间：{{timestamp}}。请输出处理计划，包括：1) 要处理的文件列表 2) 处理优先级 3) 预计处理时间",
          "variables": {
            "ftp_config": "{{inputs.ftp_config}}",
            "timestamp": "{{input_check.output.timestamp}}"
          }
        }
      },
      {
        "id": "download_csv",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import json\nimport ftplib\nimport tempfile\nimport os\nconfig = json.loads(config)\nplan = json.loads(plan)\nftp = ftplib.FTP(config['host'])\nftp.login(config['user'], config['password'])\nfiles = plan.get('files', [])\ndownloaded = []\nfor file in files:\n    local_path = os.path.join(tempfile.gettempdir(), file)\n    with open(local_path, 'wb') as f:\n        ftp.retrbinary(f'RETR {file}', f.write)\n    downloaded.append(local_path)\nftp.quit()\nreturn {'downloaded_files': downloaded, 'count': len(downloaded)}",
          "example_key": "parse_json",
          "variables": {
            "config": "{{inputs.ftp_config}}",
            "plan": "{{plan_processing.output}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "download_fallback",
        "type": "llm",
        "config": {
          "model": "deepseek-chat",
          "prompt": "FTP文件下载失败。错误信息：{{error}}。请生成一个备用处理方案，使用本地缓存文件或生成模拟数据。",
          "variables": {
            "error": "{{download_csv.error}}"
          }
        }
      },
      {
        "id": "aggregate_download",
        "type": "variable_aggregator",
        "config": {
          "variables": {
            "files_result": "{{download_csv.output}}",
            "fallback_result": "{{download_fallback.output}}"
          }
        }
      },
      {
        "id": "clean_data",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import pandas as pd\nimport json\nresult = json.loads(result)\nfiles = result.get('files_result', {}).get('downloaded_files', []) or result.get('fallback_result', {}).get('files', [])\ncleaned_data = []\nfor file in files:\n    df = pd.read_csv(file)\n    df = df.dropna()\n    df = df.drop_duplicates()\n    df['timestamp'] = pd.to_datetime(df['timestamp'], errors='coerce')\n    df = df.dropna(subset=['timestamp'])\n    cleaned_data.append(df.to_dict('records'))\nreturn {'cleaned_records': cleaned_data, 'total_rows': sum(len(d) for d in cleaned_data)}",
          "example_key": "clean_text",
          "variables": {
            "result": "{{aggregate_download.output}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "check_anomalies",
        "type": "ifelse",
        "config": {
          "condition": "{{clean_data.output.total_rows}} > 10000",
          "cases": [
            {
              "id": "high_volume",
              "condition": "true"
            },
            {
              "id": "normal_volume",
              "condition": "false"
            }
          ]
        }
      },
      {
        "id": "handle_high_volume",
        "type": "llm",
        "config": {
          "model": "deepseek-chat",
          "prompt": "检测到高数据量（{{total_rows}}行），建议分批处理。请生成分批处理策略，每批不超过5000行。",
          "variables": {
            "total_rows": "{{clean_data.output.total_rows}}"
          }
        }
      },
      {
        "id": "aggregate_volume",
        "type": "variable_aggregator",
        "config": {
          "variables": {
            "cleaned_data": "{{clean_data.output}}",
            "volume_strategy": "{{handle_high_volume.output}}"
          }
        }
      },
      {
        "id": "enrich_ip",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import json\nimport requests\ndata = json.loads(data)\napi_key = json.loads(api_key)\nrecords = data['cleaned_data']['cleaned_records']\nenriched = []\nfor batch in records:\n    for record in batch:\n        if 'ip' in record:\n            try:\n                response = requests.get(f'http://ip-api.com/json/{record[\"ip\"]}')\n                geo = response.json()\n                record['country'] = geo.get('country', 'Unknown')\n                record['city'] = geo.get('city', 'Unknown')\n            except:\n                record['country'] = 'Unknown'\n                record['city'] = 'Unknown'\n        enriched.append(record)\nreturn {'enriched_records': enriched, 'count': len(enriched)}",
          "example_key": "parse_json",
          "variables": {
            "data": "{{aggregate_volume.output}}",
            "api_key": "{{inputs.api_key}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "risk_analysis",
        "type": "llm",
        "config": {
          "model": "deepseek-chat",
          "prompt": "分析以下日志记录中的风险模式。记录数量：{{count}}。请识别：1) 可疑IP地址 2) 异常访问频率 3) 潜在安全威胁。记录示例：{{sample_records}}",
          "variables": {
            "count": "{{enrich_ip.output.count}}",
            "sample_records": "{{enrich_ip.output.enriched_records[:3]}}"
          }
        }
      },
      {
        "id": "generate_report",
        "type": "template",
        "config": {
          "template": "# 日志处理报告\n\n**运行ID**: {{run_id}}\n**处理时间**: {{timestamp}}\n**处理文件数**: {{file_count}}\n**处理记录数**: {{record_count}}\n**风险分析结果**:\n{{risk_analysis}}\n\n**状态**: {{status}}",
          "variables": {
            "run_id": "{{input_check.output.timestamp}}",
            "timestamp": "{{input_check.output.timestamp}}",
            "file_count": "{{aggregate_download.output.files_result.count}}",
            "record_count": "{{enrich_ip.output.count}}",
            "risk_analysis": "{{risk_analysis.output}}",
            "status": "已完成"
          }
        }
      },
      {
        "id": "answer",
        "type": "answer",
        "config": {
          "answer": "{{generate_report.output}}"
        }
