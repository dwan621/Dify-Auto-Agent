    "description": "每日定时处理FTP上的CSV日志文件，包括数据清洗、IP地理位置补全、风险判断和报表生成",
    "scene": "generic",
    "inputs": [
      {
        "name": "ftp_config",
        "label": "FTP配置信息",
        "type": "text",
        "required": true
      },
      {
        "name": "db_connection",
        "label": "数据库连接配置",
