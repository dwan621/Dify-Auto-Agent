    "steps": [
      {
        "id": "start",
        "type": "start",
        "config": {}
      },
      {
        "id": "input_validation",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import json\ninputs = json.loads(inputs)\nif not inputs.get('ftp_config') or not inputs.get('db_connection') or not inputs.get('api_key') or not inputs.get('monitoring_platform_url'):\n    raise ValueError('缺少必要输入参数')\nreturn {'valid': True, 'message': '输入验证通过'}",
          "variables": {
            "inputs": "{{inputs}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "ftp_connect",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import json\nimport ftplib\nfrom io import BytesIO\nconfig = json.loads(inputs['ftp_config'])\nftp = ftplib.FTP(config['host'])\nftp.login(config['user'], config['password'])\nftp.cwd(config['directory'])\nfiles = ftp.nlst()\ncsv_files = [f for f in files if f.endswith('.csv')]\nfile_contents = {}\nfor file in csv_files[:5]:\n    bio = BytesIO()\n    ftp.retrbinary(f'RETR {file}', bio.write)\n    file_contents[file] = bio.getvalue().decode('utf-8')\nftp.quit()\nreturn {'files': csv_files, 'contents': file_contents, 'count': len(csv_files)}",
          "variables": {
            "inputs": "{{inputs}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_cleaning",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import pandas as pd\nimport json\nfrom io import StringIO\ncontents = json.loads(previous_output['contents'])\ncleaned_data = {}\nfor filename, content in contents.items():\n    df = pd.read_csv(StringIO(content))\n    df = df.dropna()\n    df = df.drop_duplicates()\n    df.columns = df.columns.str.strip().str.lower()\n    cleaned_data[filename] = df.to_dict('records')\nreturn {'cleaned_data': cleaned_data, 'file_names': list(cleaned_data.keys())}",
          "example_key": "clean_text",
          "variables": {
            "previous_output": "{{ftp_connect.output}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "check_empty_data",
        "type": "ifelse",
        "config": {
          "condition": "{{data_cleaning.output.cleaned_data|length > 0}}",
          "cases": [
            {
              "id": "has_data",
              "label": "有数据"
            },
            {
              "id": "no_data",
              "label": "无数据"
            }
          ]
        }
      },
      {
        "id": "ip_geolocation",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import json\nimport requests\ncleaned_data = json.loads(previous_output['cleaned_data'])\nenhanced_data = {}\nfor filename, records in cleaned_data.items():\n    enhanced_records = []\n    for record in records:\n        if 'ip' in record:\n            try:\n                response = requests.get(f'http://ip-api.com/json/{record[\"ip\"]}', timeout=5)\n                geo = response.json()\n                record['country'] = geo.get('country', 'Unknown')\n                record['city'] = geo.get('city', 'Unknown')\n            except:\n                record['country'] = 'Unknown'\n                record['city'] = 'Unknown'\n        enhanced_records.append(record)\n    enhanced_data[filename] = enhanced_records\nreturn {'enhanced_data': enhanced_data}",
          "variables": {
            "previous_output": "{{data_cleaning.output}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "risk_analysis",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import json\nimport pandas as pd\nfrom io import StringIO\nenhanced_data = json.loads(previous_output['enhanced_data'])\nanomalies = []\nfor filename, records in enhanced_data.items():\n    df = pd.DataFrame(records)\n    if 'status_code' in df.columns:\n        error_rates = df[df['status_code'] >= 400].groupby('ip').size()\n        high_error_ips = error_rates[error_rates > 10].index.tolist()\n        for ip in high_error_ips:\n            anomalies.append({'file': filename, 'ip': ip, 'type': 'high_error_rate', 'count': int(error_rates[ip])})\n    if 'country' in df.columns:\n        suspicious_countries = ['Russia', 'North Korea', 'Iran']\n        suspicious_ips = df[df['country'].isin(suspicious_countries)]['ip'].unique().tolist()\n        for ip in suspicious_ips:\n            anomalies.append({'file': filename, 'ip': ip, 'type': 'suspicious_country', 'country': df[df['ip']==ip]['country'].iloc[0]})\nreturn {'anomalies': anomalies, 'anomaly_count': len(anomalies)}",
          "variables": {
            "previous_output": "{{ip_geolocation.output}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "db_insert",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import json\nimport sqlite3\nfrom io import StringIO\nenhanced_data = json.loads(previous_output['enhanced_data'])\ndb_config = json.loads(inputs['db_connection'])\nconn = sqlite3.connect(db_config['database'])\ncursor = conn.cursor()\ninserted_rows = 0\nfor filename, records in enhanced_data.items():\n    for record in records:\n        columns = ', '.join(record.keys())\n        placeholders = ', '.join(['?' for _ in record])\n        values = list(record.values())\n        cursor.execute(f'INSERT OR IGNORE INTO logs ({columns}) VALUES ({placeholders})', values)\n        inserted_rows += cursor.rowcount\nconn.commit()\nconn.close()\nreturn {'inserted_rows': inserted_rows}",
          "variables": {
            "previous_output": "{{ip_geolocation.output}}",
            "inputs": "{{inputs}}"
          }
        }
      },
      {
        "id": "report_generation",
        "type": "llm",
        "config": {
          "model": "deepseek-chat",
          "prompt": "基于以下处理结果生成日报：\n处理文件：{{data_cleaning.output.file_names}}\n清洗后记录数：{{len(data_cleaning.output.cleaned_data)}}\n异常检测：{{risk_analysis.output.anomaly_count}}个异常\n数据库插入：{{db_insert.output.inserted_rows}}行\n请生成结构化的日报，包含摘要、处理详情、异常汇总和建议。",
          "variables": {
            "data_cleaning.output": "{{data_cleaning.output}}",
            "risk_analysis.output": "{{risk_analysis.output}}",
            "db_insert.output": "{{db_insert.output}}"
          }
        }
      },
      {
        "id": "format_report",
        "type": "code",
        "config": {
          "language": "python",
          "script": "import json\nreport = json.loads(previous_output)\nformatted = f\"# 日志处理日报\\n\\n## 摘要\\n{report['summary']}\\n\\n## 处理详情\\n{report['details']}\\n\\n## 异常汇总\\n{report['anomalies_summary']}\\n\\n## 建议\\n{report['recommendations']}\"\nreturn {'formatted_report': formatted}",
          "example_key": "format_markdown",
          "variables": {
            "previous_output": "{{report_generation.output}}"
          }
        }
      },
      {
        "id": "aggregate_success",
        "type": "variable_aggregator",
        "config": {
          "variables": {
            "run_id": "{{generate_run_id.output}}",
            "processed_files": "{{data_cleaning.output.file_names}}",
            "inserted_rows": "{{db_insert.output.inserted_rows}}",
            "anomalies": "{{risk_analysis.output.anomalies}}",
            "alerts": "[]",
            "report": "{{format_report.output.formatted_report}}",
            "status": "success"
          }
        }
      },
      {
