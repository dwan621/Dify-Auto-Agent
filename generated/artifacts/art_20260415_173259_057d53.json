      {
        "id": "ftp_connect",
        "type": "code",
        "config": {
          "name": "连接FTP并获取文件列表",
          "language": "python",
          "script": "import ftplib\nimport json\n\ndef main(inputs):\n    ftp_config = json.loads(inputs['ftp_config'])\n    ftp = ftplib.FTP(ftp_config['host'])\n    ftp.login(ftp_config['user'], ftp_config['password'])\n    ftp.cwd(ftp_config['path'])\n    files = [f for f in ftp.nlst() if f.endswith('.csv')]\n    ftp.quit()\n    return {'files': files",
          "count": "len(files)}",
          "variables": {
            "inputs": "{{inputs}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "download_files",
        "type": "code",
        "config": {
          "name": "下载CSV文件",
          "language": "python",
          "script": "import ftplib\nimport json\nimport os\n\ndef main(inputs, ftp_result):\n    ftp_config = json.loads(inputs['ftp_config'])\n    files = ftp_result['files']\n    downloaded = []\n    \n    ftp = ftplib.FTP(ftp_config['host'])\n    ftp.login(ftp_config['user'], ftp_config['password'])\n    ftp.cwd(ftp_config['path'])\n    \n    for file in files:\n        local_path = f'/tmp/{file}'\n        with open(local_path, 'wb') as f:\n            ftp.retrbinary(f'RETR {file}', f.write)\n        downloaded.append({'name': file",
          "path": "local_path})\n    \n    ftp.quit()\n    return {'downloaded_files': downloaded}",
          "variables": {
            "inputs": "{{inputs}}",
            "ftp_result": "{{steps.ftp_connect.output}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_clean",
        "type": "code",
        "config": {
          "name": "数据清洗",
          "language": "python",
          "script": "import pandas as pd\nimport json\n\ndef main(download_result):\n    cleaned_data = []\n    for file_info in download_result['downloaded_files']:\n        df = pd.read_csv(file_info['path'])\n        # 清洗操作\n        df = df.dropna(subset=['timestamp', 'ip_address'])\n        df['timestamp'] = pd.to_datetime(df['timestamp'], errors='coerce')\n        df = df.dropna(subset=['timestamp'])\n        cleaned_data.append({\n            'file': file_info['name']",
          "data": "df.to_dict('records')",
          "rows": "len(df)\n        })\n    return {'cleaned_data': cleaned_data",
          "total_rows": "sum(item['rows'] for item in cleaned_data)}",
          "example_key": "clean_text",
          "variables": {
            "download_result": "{{steps.download_files.output}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "ip_geolocation",
        "type": "code",
        "config": {
          "name": "IP地理位置补全",
          "language": "python",
          "script": "import requests\nimport json\n\ndef main(inputs, cleaned_result):\n    api_key = inputs['api_key']\n    enriched_data = []\n    \n    for file_data in cleaned_result['cleaned_data']:\n        enriched_records = []\n        for record in file_data['data']:\n            ip = record.get('ip_address')\n            if ip:\n                try:\n                    response = requests.get(f'http://ip-api.com/json/{ip}', timeout=5)\n                    geo_data = response.json()\n                    record['country'] = geo_data.get('country', '')\n                    record['city'] = geo_data.get('city', '')\n                    record['isp'] = geo_data.get('isp', '')\n                except:\n                    record['country'] = 'Unknown'\n                    record['city'] = 'Unknown'\n                    record['isp'] = 'Unknown'\n            enriched_records.append(record)\n        \n        enriched_data.append({\n            'file': file_data['file']",
          "data": "enriched_records",
          "rows": "file_data['rows']\n        })\n    \n    return {'enriched_data': enriched_data}",
          "variables": {
            "inputs": "{{inputs}}",
            "cleaned_result": "{{steps.data_clean.output}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "risk_analysis",
        "type": "code",
        "config": {
          "name": "风险分析",
          "language": "python",
          "script": "import json\n\ndef main(enriched_result):\n    anomalies = []\n    high_risk_ips = set()\n    \n    for file_data in enriched_result['enriched_data']:\n        for record in file_data['data']:\n            # 风险判断逻辑\n            if record.get('status_code', 200) >= 500:\n                anomalies.append({\n                    'type': 'server_error'",
          "ip": "record.get('ip_address')",
          "timestamp": "record.get('timestamp')",
          "file": "file_data['file']\n                })\n                high_risk_ips.add(record.get('ip_address'))\n    \n    return {\n        'anomalies': anomalies",
          "high_risk_ips": "list(high_risk_ips)",
          "anomaly_count": "len(anomalies)\n    }",
          "variables": {
            "enriched_result": "{{steps.ip_geolocation.output}}"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "db_insert",
        "type": "code",
        "config": {
          "name": "数据入库",
          "language": "python",
          "script": "import json\nimport psycopg2\n\ndef main(inputs, enriched_result):\n    db_config = json.loads(inputs['db_connection'])\n    inserted_rows = 0\n    \n    conn = psycopg2.connect(\n        host=db_config['host'],\n        database=db_config['database'],\n        user=db_config['user'],\n        password=db_config['password']\n    )\n    cursor = conn.cursor()\n    \n    for file_data in enriched_result['enriched_data']:\n        for record in file_data['data']:\n            cursor.execute(\"\"\"\n                INSERT INTO log_entries \n                (timestamp, ip_address, country, city, isp, status_code, request_size, file_name)\n                VALUES (%s, %s, %s, %s, %s, %s, %s, %s)\n            \"\"\", (\n                record.get('timestamp'),\n                record.get('ip_address'),\n                record.get('country'),\n                record.get('city'),\n                record.get('isp'),\n                record.get('status_code', 200),\n                record.get('request_size', 0),\n                file_data['file']\n            ))\n            inserted_rows += 1\n    \n    conn.commit()\n    cursor.close()\n    conn.close()\n    \n    return {'inserted_rows': inserted_rows}",
          "variables": {
            "inputs": "{{inputs}}",
            "enriched_result": "{{steps.ip_geolocation.output}}"
          }
        }
      },
      {
        "id": "check_anomalies",
        "type": "ifelse",
        "config": {
