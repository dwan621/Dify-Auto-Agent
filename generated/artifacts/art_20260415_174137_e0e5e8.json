      {
        "id": "data_cleaning",
        "type": "code",
        "config": {
          "name": "数据清洗转换",
          "description": "清洗CSV数据，处理缺失值和格式转换",
          "language": "python",
          "script": "def clean_csv_data(csv_content):\n    import pandas as pd\n    import io\n    import json\n    \n    try:\n        # 读取CSV数据\n        df = pd.read_csv(io.StringIO(csv_content))\n        \n        # 记录原始行数\n        original_count = len(df)\n        \n        # 清洗步骤\n        # 1. 去除重复行\n        df = df.drop_duplicates()\n        \n        # 2. 处理缺失值\n        numeric_cols = df.select_dtypes(include=['number']).columns\n        df[numeric_cols] = df[numeric_cols].fillna(0)\n        \n        text_cols = df.select_dtypes(include=['object']).columns\n        df[text_cols] = df[text_cols].fillna('')\n        \n        # 3. 标准化时间格式\n        if 'timestamp' in df.columns:\n            df['timestamp'] = pd.to_datetime(df['timestamp'], errors='coerce')\n        \n        # 4. 过滤无效数据\n        df = df[df['user_id'].notna() & (df['user_id'] != '')]\n        \n        cleaned_count = len(df)\n        \n        return {\n            'success': True",
          "cleaned_data": [],
          "original_records": "original_count",
          "cleaned_records": "cleaned_count",
          "removed_records": "original_count - cleaned_count",
          "columns": "list(df.columns)\n        }\n    except Exception as e:\n        return {\n            'success': False",
          "error": "str(e)",
          "error_strategy": "fail-branch"
        },
        "example_key": "clean_text",
        "variables": {
          "csv_content": "{{steps.ftp_file_download.config.variables.response_body}}"
        },
        "error_strategy": "fail-branch"
