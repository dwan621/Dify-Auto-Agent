          "name": "输入参数校验",
          "description": "校验所有输入参数的格式与完整性",
          "language": "python",
          "script": "def validate_inputs(ftp_config, api_key, db_connection, alert_email, monitoring_platform_url):\n    errors = []\n    if not ftp_config or 'host' not in ftp_config:\n        errors.append('FTP配置缺少host信息')\n    if not api_key or len(api_key) < 10:\n        errors.append('API密钥格式错误')\n    if not db_connection or 'postgresql://' not in db_connection:\n        errors.append('数据库连接字符串格式错误')\n    if not alert_email or '@' not in alert_email:\n        errors.append('告警邮箱格式错误')\n    if not monitoring_platform_url or 'http' not in monitoring_platform_url:\n        errors.append('监控平台地址格式错误')\n    \n    return {\n        'valid': len(errors) == 0",
          "errors": "errors",
          "validated_inputs": {
            "ftp_config": "ftp_config",
            "api_key": "api_key",
            "db_connection": "db_connection",
            "alert_email": "alert_email",
            "monitoring_platform_url": "monitoring_platform_url\n        }\n    }",
