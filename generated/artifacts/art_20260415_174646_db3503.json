  "selected_spec": {
    "workflow_name": "自动化数据处理工作流",
    "description": "每日定时处理FTP服务器上的CSV日志文件，包括数据读取、清洗转换、地理位置信息补全、数据入库、业务规则判断、告警触发、报表生成以及执行结果汇总回传。支持异常捕获与断点续传。",
    "scene": "generic",
    "inputs": [
      {
        "name": "ftp_config",
        "label": "FTP服务器配置",
        "type": "text",
        "required": true
      },
      {
        "name": "api_credentials",
        "label": "外部API服务凭证",
        "type": "text",
        "required": true
      },
      {
        "name": "db_connection",
        "label": "云数据库连接信息",
        "type": "text",
        "required": true
      },
      {
        "name": "alert_rules",
        "label": "高风险操作规则定义",
        "type": "paragraph",
        "required": false
      },
      {
        "name": "report_template",
        "label": "统计报表模板",
        "type": "file",
        "required": false
      },
      {
        "name": "monitor_platform_url",
        "label": "监控平台回传地址",
        "type": "text",
        "required": true
      }
    ],
    "output_contract": {
      "final_status": "流程最终执行状态（成功/失败/部分成功）",
      "processed_records_count": "成功处理的数据记录数",
      "high_risk_alerts_triggered": "触发的高风险告警数量",
      "report_generated": "生成的统计报表文件路径或标识",
      "execution_log_summary": "关键节点执行日志的摘要",
      "error_messages": "流程中捕获的异常信息列表（如有）"
    },
    "steps": [
      {
        "id": "start",
        "type": "start",
        "config": {
          "name": "开始处理流程"
        }
      },
      {
        "id": "ftp_download",
        "type": "tool",
        "config": {
          "name": "从FTP下载CSV日志文件",
          "method": "get",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "action": "download_csv",
            "ftp_config": "{{ftp_config}}"
          },
          "variables": {
            "ftp_config": "inputs.ftp_config"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "data_cleaning",
        "type": "code",
        "config": {
          "name": "数据清洗与格式转换",
          "language": "python",
          "script": "import pandas as pd\nimport json\n\ndef clean_data(raw_data):\n    # 解析CSV数据\n    df = pd.read_csv(raw_data)\n    # 清洗空值\n    df = df.dropna()\n    # 格式标准化\n    df['timestamp'] = pd.to_datetime(df['timestamp'])\n    return df.to_dict('records')\n\ncleaned_data = clean_data(input_data)",
          "example_key": "clean_text",
          "variables": {
            "input_data": "steps.ftp_download.output.data"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "geo_enrichment",
        "type": "tool",
        "config": {
          "name": "地理位置信息补全",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": "",
          "body": {
            "data": "{{cleaned_data}}",
            "enrich_fields": [
              "ip_address",
              "location"
            ]
          },
          "variables": {
            "cleaned_data": "steps.data_cleaning.output.cleaned_data",
            "api_credentials": "inputs.api_credentials"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "db_insert",
        "type": "code",
        "config": {
          "name": "数据入库操作",
          "language": "python",
          "script": "import json\nimport psycopg2\n\ndef insert_to_db(enriched_data, db_conn):\n    conn = psycopg2.connect(db_conn)\n    cursor = conn.cursor()\n    inserted_count = 0\n    \n    for record in enriched_data:\n        cursor.execute(\"\"\"\n            INSERT INTO log_data (timestamp, ip, location, action, user_id)\n            VALUES (%s, %s, %s, %s, %s)\n        \"\"\", (\n            record['timestamp'],\n            record['ip'],\n            record.get('location', 'Unknown'),\n            record['action'],\n            record['user_id']\n        ))\n        inserted_count += 1\n    \n    conn.commit()\n    cursor.close()\n    conn.close()\n    return inserted_count\n\nprocessed_count = insert_to_db(enriched_data, db_connection)",
          "variables": {
            "enriched_data": "steps.geo_enrichment.output.enriched_data",
            "db_connection": "inputs.db_connection"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "risk_analysis",
        "type": "ifelse",
        "config": {
          "name": "高风险操作分析",
          "condition": "{{high_risk_count}} > 0",
          "cases": [
            {
              "id": "high_risk",
              "name": "存在高风险操作"
            },
            {
              "id": "normal",
              "name": "无高风险操作"
            }
          ],
          "variables": {
            "high_risk_count": "steps.db_insert.output.high_risk_count"
          }
        }
      },
      {
        "id": "trigger_alerts",
        "type": "tool",
        "config": {
          "name": "触发告警通知",
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "alerts": "{{high_risk_records}}",
            "rules": "{{alert_rules}}",
            "platform_url": "{{monitor_platform_url}}"
          },
          "variables": {
            "high_risk_records": "steps.db_insert.output.high_risk_records",
            "alert_rules": "inputs.alert_rules",
            "monitor_platform_url": "inputs.monitor_platform_url"
          },
          "error_strategy": "fail-branch"
        }
      },
      {
        "id": "generate_report",
        "type": "template",
        "config": {
          "name": "生成统计报表",
          "template": "## 数据处理报告\n\n**执行时间:** {{current_time}}\n**处理记录数:** {{processed_count}}\n**高风险操作数:** {{high_risk_count}}\n**数据质量:** {{data_quality_score}}%\n\n### 执行摘要\n{{execution_summary}}\n\n### 告警详情\n{{alerts_summary}}",
          "variables": {
            "current_time": "system.current_time",
            "processed_count": "steps.db_insert.output.processed_count",
            "high_risk_count": "steps.db_insert.output.high_risk_count",
            "data_quality_score": "steps.data_cleaning.output.quality_score",
            "execution_summary": "steps.db_insert.output.summary",
            "alerts_summary": "steps.trigger_alerts.output.alerts_summary"
          }
        }
      },
      {
        "id": "aggregate_results",
        "type": "variable_aggregator",
        "config": {
          "name": "汇总执行结果",
          "variables": {
            "final_status": "steps.db_insert.output.status",
            "processed_records_count": "steps.db_insert.output.processed_count",
            "high_risk_alerts_triggered": "steps.trigger_alerts.output.alert_count",
            "report_generated": "steps.generate_report.output.report_path",
            "execution_log_summary": "steps.db_insert.output.log_summary",
            "error_messages": "steps.ftp_download.output.errors"
          }
        }
      },
      {
        "id": "answer",
        "type": "answer",
        "config": {
          "name": "返回最终结果",
          "answer": "{{aggregated_results}}"
        }
      },
