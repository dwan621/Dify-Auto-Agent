        "id": "code_validate",
        "type": "code",
        "title": "订单数据验证",
        "config": {
          "language": "python",
          "script": "import json\n\ndef validate_order(order_data):\n    try:\n        order = json.loads(order_data)\n        required_fields = ['order_id', 'customer_id', 'items', 'total_amount']\n        for field in required_fields:\n            if field not in order:\n                return {'valid': False, 'error': f'Missing required field: {field}'}\n        \n        if not isinstance(order['items'], list) or len(order['items']) == 0:\n            return {'valid': False, 'error': 'Items must be a non-empty list'}\n        \n        if order['total_amount'] <= 0:\n            return {'valid': False, 'error': 'Total amount must be positive'}\n        \n        return {'valid': True, 'order': order}\n    except json.JSONDecodeError:\n        return {'valid': False, 'error': 'Invalid JSON format'}\n\nresult = validate_order(input)\noutput = result",
          "variables": [
            {
              "variable": "input",
              "value_selector": [
                "start",
                "order_event"
              ]
            }
          ]
        }
      },
      {
        "id": "ifelse_validation",
        "type": "ifelse",
        "title": "验证结果判断",
        "config": {
          "cases": [
            {
              "id": "valid",
              "logical_operator": "and",
              "conditions": [
                {
                  "variable": "output.valid",
                  "operator": "==",
                  "value": true
                }
              ]
            },
            {
              "id": "invalid",
              "logical_operator": "and",
              "conditions": [
                {
