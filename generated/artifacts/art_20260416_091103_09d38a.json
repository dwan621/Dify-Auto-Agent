        "config": {
          "language": "python",
          "script": "import json\n\ndef main(input_data):\n    quality_status = input_data.get('quality_status', 'UNKNOWN')\n    new_image_tag = input_data.get('new_image_tag', 'N/A')\n    deployment_status = input_data.get('deployment_status', 'UNKNOWN')\n    monitoring_metrics = input_data.get('monitoring_metrics', {})\n    rollback_status = input_data.get('rollback_status', 'N/A')\n    \n    error_rate = monitoring_metrics.get('error_rate', 0)\n    latency = monitoring_metrics.get('latency', 0)\n    \n    final_status = '成功'\n    if deployment_status == 'FAILED':\n        final_status = '失败'\n    elif rollback_status == 'SUCCESS':\n        final_status = '已回滚'\n    \n    report = f\"# CI/CD 部署报告\\n\\n\"\n    report += f\"## 构建状态\\n- 代码质量检查: {quality_status}\\n\"\n    report += f\"- Docker镜像标签: {new_image_tag}\\n\"\n    report += f\"\\n## 发布状态\\n- 部署状态: {deployment_status}\\n\"\n    report += f\"- 最终状态: {final_status}\\n\"\n    report += f\"\\n## 监控指标\\n- 错误率: {error_rate:.2%}\\n\"\n    report += f\"- 延迟: {latency}ms\\n\"\n    report += f\"\\n## 回滚状态\\n- 回滚操作: {rollback_status}\\n\"\n    \n    return {\n        'final_report': report,\n        'pipeline_log_url': 'https://logs.example.com/pipeline-12345',\n        'deployment_status': final_status,\n        'new_image_tag': new_image_tag\n    }\n\nresult = main(input)",
          "example_key": "format_markdown",
          "variables": [
