      {
        "id": "data_cleaning",
        "type": "code",
        "title": "数据清洗",
        "config": {
          "language": "python",
          "script": "def clean_data(download_result):\n    # 模拟数据清洗过程\n    files = download_result.get('files', [])\n    cleaned_data = []\n    processed_files = []\n    \n    for file in files:\n        # 清洗逻辑\n        cleaned_data.append({\n            'file': file,\n            'status': 'cleaned',\n            'records': 100\n        })\n        processed_files.append(file)\n    \n    return {\n        'cleaned_data': cleaned_data,\n        'processed_files': processed_files,\n        'total_records': len(cleaned_data) * 100\n    }",
          "example_key": "clean_text",
          "variables": [
            {
              "variable": "download_result",
              "value_selector": [
                "ftp_download",
                "response"
              ]
            }
          ]
        }
      },
