        "id": "data_completion",
        "type": "llm",
        "title": "数据补全",
        "config": {
          "prompt": "请对以下清洗后的数据进行智能补全，填充缺失字段，确保数据完整性：\n{{data_cleaning.cleaned_data}}\n\n要求：\n1. 保持数据结构一致\n2. 补充合理的默认值\n3. 标记补全的记录",
          "variables": [
            {
              "variable": "data_cleaning.cleaned_data",
              "value_selector": [
                "data_cleaning",
                "cleaned_data"
              ]
            }
          ]
        }
      },
