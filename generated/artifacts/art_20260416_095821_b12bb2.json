    "steps": [
      {
        "id": "start",
        "type": "start",
        "title": "开始"
      },
      {
        "id": "code_ftp_download",
        "type": "code",
        "title": "FTP数据下载与解析",
        "config": {
          "language": "python",
          "script": "import json\nimport pandas as pd\nfrom io import StringIO\n\n# 解析FTP配置\nftp_config = json.loads(variables['ftp_config'])\n# 模拟FTP连接和数据下载（实际实现需使用ftplib等库）\n# 这里返回模拟的CSV数据\ncsv_data = \"timestamp,user_id,action,ip_address,amount\\n2024-01-01 10:00:00,user1,login,192.168.1.1,0\\n2024-01-01 10:05:00,user2,purchase,192.168.1.2,150.50\\n2024-01-01 10:10:00,user3,login,192.168.1.3,0\\n2024-01-01 10:15:00,user4,purchase,192.168.1.4,2000.00\"\ndf = pd.read_csv(StringIO(csv_data))\n# 返回处理后的数据\nresult = {\n    'raw_data': csv_data,\n    'dataframe': df.to_dict('records'),\n    'row_count': len(df),\n    'status': 'success'\n}\nreturn result",
          "example_key": "parse_json",
          "variables": [
            {
              "variable": "ftp_config",
              "value_selector": [
                "start",
                "ftp_config"
              ]
            }
          ]
        }
      },
      {
        "id": "code_data_clean",
        "type": "code",
        "title": "数据清洗与转换",
        "config": {
          "language": "python",
          "script": "import pandas as pd\nimport json\n\n# 将数据转换回DataFrame\ndf = pd.DataFrame(variables['dataframe'])\n\n# 数据清洗步骤\n# 1. 转换timestamp列为datetime类型\ndf['timestamp'] = pd.to_datetime(df['timestamp'])\n# 2. 处理缺失值\ndf['amount'] = df['amount'].fillna(0)\n# 3. 标准化action列\ndf['action'] = df['action'].str.lower()\n# 4. 添加处理标记\ndf['processed_at'] = pd.Timestamp.now()\n\n# 返回清洗后的数据\nresult = {\n    'cleaned_data': df.to_dict('records'),\n    'cleaned_row_count': len(df),\n    'cleaning_summary': {\n        'missing_values_filled': df['amount'].isna().sum(),\n        'actions_standardized': True\n    },\n    'status': 'success'\n}\nreturn result",
          "example_key": "clean_text",
          "variables": [
            {
              "variable": "dataframe",
              "value_selector": [
                "code_ftp_download",
                "dataframe"
              ]
            }
          ]
        }
      },
      {
        "id": "tool_geo_lookup",
        "type": "tool",
        "title": "地理位置信息补全",
        "config": {
          "method": "post",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "ips": "{{unique_ips}}",
            "credentials": "{{api_credentials}}"
          },
          "variables": [
            {
              "variable": "unique_ips",
              "value_selector": [
                "code_data_clean",
                "cleaned_data",
                "ip_address"
              ]
            },
            {
              "variable": "api_credentials",
              "value_selector": [
                "start",
                "api_credentials"
              ]
            }
          ]
        }
      },
      {
        "id": "code_db_upload",
        "type": "code",
        "title": "数据入库",
        "config": {
          "language": "python",
          "script": "import json\nimport pandas as pd\n\n# 解析数据库连接信息\ndb_config = json.loads(variables['db_connection'])\n\n# 合并清洗后的数据和地理位置信息\ncleaned_df = pd.DataFrame(variables['cleaned_data'])\ngeo_data = json.loads(variables['geo_response'])\n\n# 模拟数据库上传操作\n# 实际实现应使用相应的数据库驱动\nupload_status = {\n    'rows_inserted': len(cleaned_df),\n    'database': db_config.get('database_name', 'unknown'),\n    'timestamp': pd.Timestamp.now().isoformat(),\n    'status': 'success'\n}\n\n# 准备业务分析数据\nanalysis_data = {\n    'total_transactions': len(cleaned_df[cleaned_df['action'] == 'purchase']),\n    'total_amount': cleaned_df['amount'].sum(),\n    'unique_users': cleaned_df['user_id'].nunique(),\n    'high_value_flag': cleaned_df['amount'].max() > 1000\n}\n\nreturn {\n    'upload_status': upload_status,\n    'analysis_data': analysis_data,\n    'status': 'success'\n}",
          "example_key": "parse_json",
          "variables": [
            {
              "variable": "db_connection",
              "value_selector": [
                "start",
                "db_connection"
              ]
            },
            {
              "variable": "cleaned_data",
              "value_selector": [
                "code_data_clean",
                "cleaned_data"
              ]
            },
            {
              "variable": "geo_response",
              "value_selector": [
                "tool_geo_lookup",
                "response"
              ]
            }
          ]
        }
      },
      {
        "id": "ifelse_alert_check",
        "type": "ifelse",
        "title": "告警规则检查",
        "config": {
          "cases": [
            {
              "id": "trigger_alert",
              "logical_operator": "or",
              "conditions": [
                {
                  "variable": "high_value_flag",
                  "operator": "==",
                  "value": true
                },
                {
                  "variable": "total_amount",
                  "operator": ">",
                  "value": 1000
                }
              ]
            },
            {
              "id": "no_alert",
              "logical_operator": "and",
              "conditions": []
            }
          ]
        }
      },
      {
        "id": "llm_report_generation",
        "type": "llm",
        "title": "报表生成",
        "config": {
          "prompt": "基于以下数据处理结果生成每日统计报表：\n\n数据概览：\n- 总交易笔数：{{total_transactions}}\n- 总交易金额：{{total_amount}}\n- 独立用户数：{{unique_users}}\n- 数据入库状态：{{upload_status}}\n- 地理位置补全：{{geo_status}}\n\n请生成结构化的报表，包含：\n1. 执行摘要\n2. 关键指标\n3. 数据质量评估\n4. 建议与后续步骤\n\n报表格式要求：使用Markdown格式，清晰易读。",
          "variables": [
            {
              "variable": "total_transactions",
              "value_selector": [
                "code_db_upload",
                "analysis_data",
                "total_transactions"
              ]
            },
            {
