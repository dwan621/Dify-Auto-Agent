    "steps": [
      {
        "id": "start",
        "type": "start",
        "title": "开始"
      },
      {
        "id": "code_ftp_download",
        "type": "code",
        "title": "FTP数据下载与解析",
        "config": {
          "language": "python",
          "script": "import json\nimport pandas as pd\nfrom io import StringIO\n\n# 解析FTP配置\nftp_config = json.loads(variables['ftp_config'])\n# 模拟FTP连接和数据下载（实际实现需使用ftplib等库）\n# 这里假设下载的CSV数据已获取到csv_content变量中\ncsv_content = \"\"\"timestamp,user_id,action,ip_address,amount\n2023-10-01 10:00:00,user001,login,192.168.1.1,0\n2023-10-01 10:05:00,user002,purchase,192.168.1.2,1500\n2023-10-01 10:10:00,user003,login,192.168.1.3,0\n2023-10-01 10:15:00,user004,refund,192.168.1.4,-500\n\"\"\"\n\n# 解析CSV\nif csv_content:\n    df = pd.read_csv(StringIO(csv_content))\n    result = {\n        \"raw_data\": df.to_dict('records'),\n        \"record_count\": len(df),\n        \"status\": \"success\",\n        \"message\": f\"成功下载并解析{len(df)}条记录\"\n    }\nelse:\n    result = {\n        \"raw_data\": [],\n        \"record_count\": 0,\n        \"status\": \"error\",\n        \"message\": \"未获取到数据\"\n    }\n\noutput = json.dumps(result)",
          "example_key": "parse_json",
          "variables": [
            {
              "variable": "ftp_config",
              "value_selector": [
                "start",
                "ftp_config"
              ]
            }
          ]
        }
      },
      {
        "id": "code_data_clean",
        "type": "code",
        "title": "数据清洗与转换",
        "config": {
          "language": "python",
          "script": "import json\nimport pandas as pd\nfrom datetime import datetime\n\n# 获取上游数据\ndownload_result = json.loads(variables['ftp_data'])\nraw_data = download_result.get('raw_data', [])\n\nif not raw_data:\n    output = json.dumps({\n        \"cleaned_data\": [],\n        \"status\": \"error\",\n        \"message\": \"无数据可清洗\"\n    })\nelse:\n    df = pd.DataFrame(raw_data)\n    \n    # 数据清洗步骤\n    # 1. 去除重复记录\n    df = df.drop_duplicates()\n    \n    # 2. 处理缺失值\n    df['amount'] = df['amount'].fillna(0)\n    \n    # 3. 标准化时间格式\n    df['timestamp'] = pd.to_datetime(df['timestamp'])\n    \n    # 4. 验证数据有效性\n    valid_mask = df['user_id'].notna() & df['action'].notna()\n    df = df[valid_mask]\n    \n    result = {\n        \"cleaned_data\": df.to_dict('records'),\n        \"record_count\": len(df),\n        \"cleaning_stats\": {\n            \"original_count\": download_result.get('record_count', 0),\n            \"cleaned_count\": len(df),\n            \"removed_count\": download_result.get('record_count', 0) - len(df)\n        },\n        \"status\": \"success\",\n        \"message\": f\"成功清洗{len(df)}条记录\"\n    }\n    output = json.dumps(result)",
          "example_key": "clean_text",
          "variables": [
            {
              "variable": "ftp_data",
              "value_selector": [
                "code_ftp_download",
                "output"
              ]
            }
          ]
        }
      },
      {
        "id": "tool_geo_lookup",
        "type": "tool",
        "title": "地理位置信息补全",
        "config": {
          "method": "get",
          "url": "https://httpbin.org/get",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "ips": "{{ips}}",
            "credentials": "{{api_credentials}}"
          },
          "variables": [
            {
              "variable": "ips",
              "value_selector": [
                "code_data_clean",
                "output",
                "cleaned_data",
                "ip_address"
              ]
            },
            {
              "variable": "api_credentials",
              "value_selector": [
                "start",
                "api_credentials"
              ]
            }
          ]
        }
      },
      {
        "id": "code_db_insert",
        "type": "code",
        "title": "数据入库",
        "config": {
          "language": "python",
          "script": "import json\n\n# 获取清洗后的数据和地理位置信息\ncleaned_data = json.loads(variables['cleaned_data'])\ngeo_data = json.loads(variables['geo_data'])\ndb_connection = variables['db_connection']\n\n# 合并数据\nfor record in cleaned_data.get('cleaned_data', []):\n    ip = record.get('ip_address', '')\n    # 查找对应的地理位置信息\n    geo_info = next((g for g in geo_data.get('geo_results', []) if g.get('ip') == ip), {})\n    record.update({\n        \"country\": geo_info.get('country', 'Unknown'),\n        \"city\": geo_info.get('city', 'Unknown'),\n        \"latitude\": geo_info.get('latitude', 0),\n        \"longitude\": geo_info.get('longitude', 0)\n    })\n\n# 模拟数据库插入操作\n# 实际实现需使用相应的数据库驱动\ninserted_count = len(cleaned_data.get('cleaned_data', []))\n\nresult = {\n    \"inserted_records\": cleaned_data.get('cleaned_data', []),\n    \"inserted_count\": inserted_count,\n    \"db_status\": \"success\" if inserted_count > 0 else \"warning\",\n    \"message\": f\"成功插入{inserted_count}条记录到数据库\"\n}\noutput = json.dumps(result)",
          "example_key": "parse_json",
          "variables": [
            {
              "variable": "cleaned_data",
              "value_selector": [
                "code_data_clean",
                "output"
              ]
            },
            {
              "variable": "geo_data",
              "value_selector": [
                "tool_geo_lookup",
                "output"
              ]
            },
            {
              "variable": "db_connection",
              "value_selector": [
                "start",
                "db_connection"
              ]
            }
          ]
        }
      },
      {
        "id": "ifelse_alert_check",
        "type": "ifelse",
        "title": "高风险操作检查",
        "config": {
          "cases": [
            {
              "id": "high_risk",
              "logical_operator": "or",
              "conditions": [
                {
                  "variable": "db_data",
                  "operator": "contains",
                  "value": "high_risk_action"
