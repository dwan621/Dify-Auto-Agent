              ]
            }
          ]
        }
      },
      {
        "id": "llm_generate_report",
        "type": "llm",
        "title": "生成统计报表",
        "config": {
          "model": "deepseek-chat",
          "prompt": "基于以下数据处理结果生成一份每日统计报告：\n\n处理数据总量：{{total_records}}条\n成功入库记录：{{inserted_count}}条\n高风险操作数量：{{high_risk_count}}条\n地理位置补全成功率：{{geo_success_rate}}%\n\n请生成包含以下章节的报告：\n1. 执行摘要\n2. 数据处理统计\n3. 风险分析\n4. 建议与改进\n\n报告格式要求：使用Markdown格式，包含表格和关键指标突出显示。",
          "variables": [
            {
              "variable": "total_records",
              "value_selector": [
